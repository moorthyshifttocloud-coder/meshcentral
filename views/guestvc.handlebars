</div>

<!-- PARTICIPANT DRAWER OVERLAY -->
<div id="drawerOverlay" onclick="closeDrawer()"></div>

<!-- PARTICIPANT DRAWER -->
<div id="participantDrawer">
    <div id="drawerHeader">
        <div id="drawerTitle">
            <svg viewBox="0 0 24 24"><path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/></svg>
            Participants
            <span id="drawerCountBadge">1</span>
        </div>
        <button id="drawerCloseBtn" onclick="closeDrawer()">
            <svg viewBox="0 0 24 24"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/></svg>
        </button>
    </div>
    <div id="participantList"></div>
</div>

<!-- SETTINGS DRAWER -->
<div id="settingsDrawer">
    <div id="settingsHeader">
        <div id="settingsTitle">Settings</div>
        <button id="settingsCloseBtn" onclick="closeSettings()">
            <svg viewBox="0 0 24 24"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/></svg>
        </button>
    </div>
    <div id="settingsTabs">
        <button class="sett-tab active" onclick="switchSettTab('media', this)">Media</button>
        <button class="sett-tab" onclick="switchSettTab('background', this)">Background</button>
        <button class="sett-tab" onclick="switchSettTab('recording', this)">Recording</button>
    </div>
    <div id="settingsBody">
        <!-- Media Tab -->
        <div class="sett-section active" id="sett-media">
            <div>
                <div class="sett-label">Camera</div>
                <select class="sett-select" id="camSelect" onchange="switchCamera(this.value)">
                    <option value="">Loading cameras…</option>
                </select>
            </div>
            <div>
                <div class="sett-label">Microphone</div>
                <select class="sett-select" id="micSelect" onchange="switchMic(this.value)">
                    <option value="">Loading mics…</option>
                </select>
            </div>
            <div>
                <div class="sett-label">Speaker</div>
                <select class="sett-select" id="speakerSelect" onchange="switchSpeaker(this.value)">
                    <option value="">Loading speakers…</option>
                </select>
            </div>
            <div class="sett-toggle-row">
                <span class="sett-toggle-label">Camera</span>
                <label class="sett-toggle"><input type="checkbox" id="settCamToggle" checked onchange="toggleCam()"><span class="sett-slider"></span></label>
            </div>
            <div class="sett-toggle-row">
                <span class="sett-toggle-label">Microphone</span>
                <label class="sett-toggle"><input type="checkbox" id="settMicToggle" checked onchange="toggleMic()"><span class="sett-slider"></span></label>
            </div>
        </div>
        <!-- Background Tab -->
        <div class="sett-section" id="sett-background">
            <div class="sett-label">Virtual Background</div>
            <div class="bg-options">
                <div class="bg-option selected" id="bg-none" onclick="setBg('none', this)">None</div>
                <div class="bg-option" id="bg-blur" onclick="setBg('blur', this)">Blur</div>
                <div class="bg-option bg-office" id="bg-office" onclick="setBg('office', this)">Office</div>
                <div class="bg-option bg-nature" id="bg-nature" onclick="setBg('nature', this)">Nature</div>
            </div>
            <p style="font-size:11px;color:var(--text-dim);line-height:1.5;">Virtual backgrounds require BackgroundBlur/VirtualBackground processors from the LiveKit client SDK. If unsupported, the option will be silently skipped.</p>
        </div>
        <!-- Recording Tab -->
        <div class="sett-section" id="sett-recording">
            <p id="recTabInfo">Record this call to a file. Recording requires a configured <code style="font-family:DM Mono,monospace;font-size:11px;color:var(--accent)">/api/startrecording</code> endpoint on the server.</p>
            <div style="display:flex;align-items:center;gap:8px;padding:8px 12px;background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius-sm);">
                <div id="recStatusDot" style="width:8px;height:8px;border-radius:50%;background:var(--text-dim);flex-shrink:0;"></div>
                <span id="recStatusText" style="font-size:12px;color:var(--text-dim);">Not recording</span>
            </div>
            <button id="recToggleBtn" class="idle" onclick="toggleRecording()">Start Recording</button>
        </div>
    </div>
</div>

<!-- HOST END CALL MODAL -->
<div id="endCallModalOverlay">
    <div id="endCallModal">
        <h3>Leave this call?</h3>
        <p>Choose whether to leave and let others continue, or end the call for everyone.</p>
        <div class="modal-btn-row">
            <button class="modal-btn leave" onclick="doLeaveCall()">
                <svg viewBox="0 0 24 24"><path d="M10.09 15.59L11.5 17l5-5-5-5-1.41 1.41L12.67 11H3v2h9.67l-2.58 2.59zM19 3H5c-1.11 0-2 .9-2 2v4h2V5h14v14H5v-4H3v4c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2z"/></svg>
                Leave Call
            </button>
            <button class="modal-btn end-all" onclick="doEndForAll()">
                <svg viewBox="0 0 24 24"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
                End for All
            </button>
            <button class="modal-btn cancel" onclick="closeEndModal()">Cancel</button>
        </div>
    </div>
</div>

<div id="toast"></div>
<!-- Multiple audio elements to handle multiple remote participants -->
<div id="audioElements"></div>

<!-- JOIN OVERLAY (rendered at end so it's on top) -->
<div id="joinOverlay">
    <div id="joinCard">
        <div id="previewWrap">
            <video id="previewVideo" class="mirrored" autoplay muted playsinline></video>
            <div id="previewNoCamera">
                <svg viewBox="0 0 24 24"><path d="M21 6.5l-4-4-5 5-3-3-4.5 4.5 8.5 8.5L21 6.5zM3.27 2 2 3.27l4.5 4.5L2 12.5V17c0 .55.45 1 1 1h11.73l2 2L18 18.73 3.27 2zM16 12.27V17H5.27L16 6.27v6z"/></svg>
                <span>Camera not available</span>
            </div>
        </div>
        <div style="text-align:center; display:flex; flex-direction:column; gap:6px;">
            <h2>Ready to join?</h2>
            <p id="joinSubtitle">Your camera and mic will be enabled.</p>
        </div>
        <button id="joinBtn" onclick="doJoin()">Join Now</button>
    </div>
</div>

<script>
// ── State ────────────────────────────────────────────────────────────────────
var room               = null;
var sdk                = null;
var micEnabled         = true;
var camEnabled         = true;
var screenTrack        = null;
var screenSid          = null;
var callStartTime      = null;
var timerInterval      = null;
var micAvailable       = true;
var camAvailable       = true;
var pinnedId           = 'local';
var remoteTracks       = {};       // sid/identity → { track, name, isScreen, tileEl, videoEl, ... }
var remoteParticipants = {};       // identity → { name, micMuted, speaking }
var activeSpeakers     = new Set();
var recordState        = 'idle';   // idle | recording | stopping
var currentEgressId    = null;
var currentBg          = 'none';
var settingsOpen       = false;
var reconnectAttempted = false;

var urlParams = new URLSearchParams(window.location.search);
var roomId    = urlParams.get('room');
var token     = urlParams.get('token');
var isHost    = urlParams.get('role') === 'host' || urlParams.get('host') === '1' || urlParams.get('host') === 'true';

// ── Recording ────────────────────────────────────────────────────────────────
async function toggleRecording() {
    if (recordState === 'idle') {
        recordState = 'recording';
        updateRecordUI();
        try {
            var res = await fetch('/api/startrecording', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ roomId: roomId })
            });
            if (!res.ok) throw new Error('Status ' + res.status);
            var data = await res.json();
            if (data.egressId) {
                currentEgressId = data.egressId;
                showToast('Recording started');
                document.getElementById('recordingBorder').classList.add('active');
                document.getElementById('recStatusDot').style.background = 'var(--red)';
                document.getElementById('recStatusDot').style.boxShadow = '0 0 6px var(--red)';
                document.getElementById('recStatusDot').style.animation = 'blink 1.4s ease-in-out infinite';
                document.getElementById('recStatusText').textContent = 'Recording…';
                document.getElementById('recStatusText').style.color = 'var(--red)';
            } else { throw new Error('No egressId returned'); }
        } catch(e) {
            recordState = 'idle';
            updateRecordUI();
            showToast('Recording failed: ' + e.message);
        }
    } else if (recordState === 'recording') {
        if (!currentEgressId) return;
        recordState = 'stopping';
        updateRecordUI();
        try {
            var res = await fetch('/api/stoprecording', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ egressId: currentEgressId })
            });
            if (!res.ok) throw new Error('Status ' + res.status);
            currentEgressId = null;
            recordState = 'idle';
            updateRecordUI();
            showToast('Recording stopped');
            document.getElementById('recordingBorder').classList.remove('active');
            document.getElementById('recStatusDot').style.background = 'var(--text-dim)';
            document.getElementById('recStatusDot').style.boxShadow = '';
            document.getElementById('recStatusDot').style.animation = '';
            document.getElementById('recStatusText').textContent = 'Not recording';
            document.getElementById('recStatusText').style.color = 'var(--text-dim)';
        } catch(e) {
            recordState = 'recording'; updateRecordUI();
            showToast('Could not stop recording: ' + e.message);
        }
    }
}

function updateRecordUI() {
    var btn = document.getElementById('recordBtn');
    var txt = document.getElementById('recordText');
    var recBtn = document.getElementById('recToggleBtn');
    if (!btn) return;
    if (recordState === 'idle') {
        btn.className = ''; btn.disabled = false; txt.innerText = 'REC';
        if (recBtn) { recBtn.className = 'idle'; recBtn.disabled = false; recBtn.textContent = 'Start Recording'; }
    } else if (recordState === 'recording') {
        btn.className = 'recording'; btn.disabled = false; txt.innerText = 'Recording';
        if (recBtn) { recBtn.className = 'recording'; recBtn.disabled = false; recBtn.textContent = 'Stop Recording'; }
    } else if (recordState === 'stopping') {
        btn.className = ''; btn.disabled = true; txt.innerText = 'Stopping…';
        if (recBtn) { recBtn.className = 'idle'; recBtn.disabled = true; recBtn.textContent = 'Stopping…'; }
    }
}

function stopRecordingIfNeeded() {
    if (recordState === 'recording' && currentEgressId) {
        fetch('/api/stoprecording', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ egressId: currentEgressId })
        }).catch(function(){});
        recordState = 'stopping'; updateRecordUI();
    }
}

// ── Timer ────────────────────────────────────────────────────────────────────
function startTimer() {
    callStartTime = Date.now();
    timerInterval = setInterval(function() {
        var s = Math.floor((Date.now() - callStartTime) / 1000);
        var m = Math.floor(s/60); s = s%60;
        var h = Math.floor(m/60); m = m%60;
        document.getElementById('callTimer').innerText =
            (h > 0 ? h+':' : '') + (h > 0 ? String(m).padStart(2,'0') : m) + ':' + String(s).padStart(2,'0');
    }, 1000);
}

// ── Toast ────────────────────────────────────────────────────────────────────
function showToast(msg, dur) {
    var t = document.getElementById('toast');
    t.innerText = msg; t.classList.add('show');
    clearTimeout(t._t);
    t._t = setTimeout(function(){ t.classList.remove('show'); }, dur || 2500);
}

// ── Status ───────────────────────────────────────────────────────────────────
function setStatus(state) {
    document.getElementById('statusPill').className = state;
    document.getElementById('statusText').innerText =
        state === 'connected' ? 'Connected' :
        state === 'error'     ? 'Error'     : 'Connecting…';
    document.getElementById('roomLabel').innerText = roomId ? '· ' + roomId : '';
}

// ── Preview ───────────────────────────────────────────────────────────────────
async function previewCamera() {
    try {
        var s = await navigator.mediaDevices.getUserMedia({ video:true, audio:false });
        document.getElementById('previewVideo').srcObject = s;
    } catch(e) {
        document.getElementById('previewVideo').style.display = 'none';
        document.getElementById('previewNoCamera').style.display = 'flex';
        document.getElementById('joinSubtitle').innerText = 'Camera unavailable — you can still join.';
    }
}
previewCamera();

// ── doJoin ───────────────────────────────────────────────────────────────────
function doJoin() {
    var pv = document.getElementById('previewVideo');
    if (pv.srcObject) { pv.srcObject.getTracks().forEach(function(t){ t.stop(); }); }
    document.getElementById('joinOverlay').style.display = 'none';
    start();
}

// ── Main connect ──────────────────────────────────────────────────────────────
async function start() {
    if (room !== null) {
        console.log('[CONNECT] WARNING: room already exists, state:', room.state);
        try { await room.disconnect(); } catch(e){}
        await new Promise(function(r){ setTimeout(r, 500); });
        room = null;
    }

    console.log('[CONNECT] start() called, roomId:', roomId, 'token length:', token ? token.length : 0);
    if (!roomId || !token) { setStatus('error'); showToast('Missing room or token', 5000); return; }
    sdk = window.LiveKitClient || window.LivekitClient;
    console.log('[CONNECT] SDK found:', !!sdk, 'SDK keys:', sdk ? Object.keys(sdk).slice(0,10).join(',') : 'none');
    if (!sdk) { setStatus('error'); showToast('LiveKit SDK not loaded', 5000); return; }
    setStatus('connecting');

    try {
        room = new sdk.Room({
            adaptiveStream: true,
            dynacast: true,
        });
        console.log('[CONNECT] room object created');

        // ── Room events ──────────────────────────────────────────
        room.on(sdk.RoomEvent.MediaDevicesError, function(error) {
            console.log('[CONNECT] MediaDevicesError', error.name, error.message);
        });
        room.on(sdk.RoomEvent.SignalConnected, function() {
            console.log('[CONNECT] SignalConnected fired');
        });
        room.on(sdk.RoomEvent.Connected, function() {
            console.log('[CONNECT] Connected event fired, room.state:', room.state);
        });

        room.on(sdk.RoomEvent.TrackSubscribed, function(track, pub, participant) {
            console.log('[CONNECT] TrackSubscribed:', track.kind, 'from', participant ? participant.identity : 'unknown', 'source:', track.source);
            if (participant) {
                if (!remoteParticipants[participant.identity]) {
                    remoteParticipants[participant.identity] = { name: participant.identity, micMuted: false, speaking: false };
                    addParticipantTile(participant);
                }
            }
            if (track.kind === 'video') {
                updateParticipantVideo(participant, track);
            }
            if (track.kind === 'audio') {
                attachRemoteAudio(participant, track);
            }
            updateParticipantCount();
            renderParticipantList();
        });

        room.on(sdk.RoomEvent.TrackUnsubscribed, function(track, pub, participant) {
            console.log('[CONNECT] TrackUnsubscribed:', track.kind, 'from', participant ? participant.identity : 'unknown');
            if (track.kind === 'video' && participant) {
                clearParticipantVideo(participant);
            }
            if (track.kind === 'audio' && participant) {
                detachRemoteAudio(participant.identity);
            }
        });

        room.on(sdk.RoomEvent.ParticipantConnected, function(p) {
            console.log('[CONNECT] ParticipantConnected:', p.identity);
            remoteParticipants[p.identity] = { name: p.identity, micMuted: false, speaking: false };
            addParticipantTile(p);
            updateParticipantCount();
            renderParticipantList();
            showToast(p.identity + ' joined');
        });

        room.on(sdk.RoomEvent.ParticipantDisconnected, function(p) {
            console.log('[CONNECT] ParticipantDisconnected:', p.identity);
            delete remoteParticipants[p.identity];
            removeParticipantTile(p.identity);
            detachRemoteAudio(p.identity);
            updateParticipantCount();
            renderParticipantList();
            showToast(p.identity + ' left the call');
        });

        // ── Mute events ──────────────────────────────────────────
        room.on(sdk.RoomEvent.TrackMuted, function(pub, participant) {
            if (pub.kind === 'audio') {
                console.log('[MIC] TrackMuted:', participant ? participant.identity : 'unknown');
                if (participant) {
                    var smuteEl = document.getElementById('smute_' + participant.identity);
                    if (smuteEl) smuteEl.classList.add('show');
                    if (pinnedId === participant.identity) {
                        document.getElementById('mainMutedBadge').classList.add('show');
                    }
                    if (remoteParticipants[participant.identity]) {
                        remoteParticipants[participant.identity].micMuted = true;
                    }
                    renderParticipantList();
                }
            }
        });

        room.on(sdk.RoomEvent.TrackUnmuted, function(pub, participant) {
            if (pub.kind === 'audio') {
                console.log('[MIC] TrackUnmuted:', participant ? participant.identity : 'unknown');
                if (participant) {
                    var smuteEl = document.getElementById('smute_' + participant.identity);
                    if (smuteEl) smuteEl.classList.remove('show');
                    if (pinnedId === participant.identity) {
                        document.getElementById('mainMutedBadge').classList.remove('show');
                    }
                    if (remoteParticipants[participant.identity]) {
                        remoteParticipants[participant.identity].micMuted = false;
                    }
                    renderParticipantList();
                }
            }
        });

        // ── Active speakers ──────────────────────────────────────
        room.on(sdk.RoomEvent.ActiveSpeakersChanged, function(speakers) {
            // speakers is an array of Participant objects
            var newSpeakers = new Set();
            speakers.forEach(function(p) { newSpeakers.add(p.identity); });

            // Update all tiles
            document.querySelectorAll('.s-tile').forEach(function(tile) {
                var tileId = tile.id.replace(/^s_/, '');
                var isSpeaking = newSpeakers.has(tileId) || (tileId === 'local' && (room.localParticipant && newSpeakers.has(room.localParticipant.identity)));
                tile.classList.toggle('speaking', isSpeaking);
            });

            // Update main view glow
            var mainSpeaking = false;
            if (pinnedId === 'local') {
                mainSpeaking = room.localParticipant && newSpeakers.has(room.localParticipant.identity);
            } else {
                mainSpeaking = newSpeakers.has(pinnedId);
            }
            document.getElementById('mainView').classList.toggle('speaking', mainSpeaking);

            // Update participant list speaking dots
            if (remoteParticipants) {
                Object.keys(remoteParticipants).forEach(function(id) {
                    if (remoteParticipants[id]) {
                        remoteParticipants[id].speaking = newSpeakers.has(id);
                    }
                });
            }
            activeSpeakers = newSpeakers;
            renderParticipantList();
        });

        // ── Data messages ────────────────────────────────────────
        room.on(sdk.RoomEvent.DataReceived, function(payload, participant) {
            try {
                var msg = JSON.parse(new TextDecoder().decode(payload));
                if (msg && msg.action === 'endForAll') {
                    showToast('Host ended the call', 3000);
                    setTimeout(function() { endCallScreen(); }, 2000);
                }
            } catch(e) {}
        });

        // ── Disconnect / reconnect ───────────────────────────────
        room.on(sdk.RoomEvent.Disconnected, function(reason) {
            console.log('[CONNECT] Disconnected reason:', reason);
            setStatus('error'); clearInterval(timerInterval);
            if (!reconnectAttempted) {
                reconnectAttempted = true;
                showToast('Disconnected. Reconnecting…', 4000);
                setTimeout(function(){
                    reconnectAttempted = false;
                    start();
                }, 3000);
            } else {
                showToast('Could not reconnect. Please refresh.', 6000);
            }
        });

        // ── Connect ──────────────────────────────────────────────
        var proto = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
        var connectUrl = proto + '//' + window.location.host;
        console.log('[CONNECT] Before room.connect, url:', connectUrl);
        await room.connect(connectUrl, token, { autoSubscribe: true });
        console.log('[CONNECT] After room.connect resolves, room.state:', room.state, 'room.name:', room.name);
        setStatus('connected');
        startTimer();
        populateDeviceSelectors();

        // Populate existing remote participants
        var existingParticipants = room.remoteParticipants || room.participants;
        if (existingParticipants) {
            existingParticipants.forEach(function(p) {
                remoteParticipants[p.identity] = { name: p.identity, micMuted: false, speaking: false };
                addParticipantTile(p);
                var tracks = p.videoTracks || p.tracks;
                if (tracks) {
                    tracks.forEach(function(pub) {
                        if (pub.track && pub.kind === 'video') updateParticipantVideo(p, pub.track);
                        if (pub.track && pub.kind === 'audio') attachRemoteAudio(p, pub.track);
                    });
                }
            });
        }
        updateParticipantCount();
        renderParticipantList();

        // ── Media capture with fallback ──────────────────────────
        var tracks = [];
        console.log('[CONNECT] media capture starting');
        try {
            tracks = await sdk.createLocalTracks({ audio:true, video:true });
            console.log('[CONNECT] media capture success (audio+video)');
            micAvailable = true; camAvailable = true;
        } catch(e) {
            console.log('[CONNECT] audio+video failed:', e.name);
            try {
                tracks = await sdk.createLocalTracks({ audio:true, video:false });
                console.log('[CONNECT] media capture success (audio only)');
                micAvailable = true; camAvailable = false;
                showToast('Camera unavailable — audio only');
            } catch(e2) {
                console.log('[CONNECT] audio only failed:', e2.name);
                try { tracks = await sdk.createLocalTracks({ audio:false, video:false }); } catch(e3){}
                micAvailable = false; camAvailable = false;
                showToast('Mic and camera unavailable — listener mode');
            }
        }

        if (!micAvailable) {
            micEnabled = false;
            var mb = document.getElementById('micBtn');
            mb.disabled = true; mb.title = 'Microphone not available';
            setMicUI(false);
        }
        if (!camAvailable) {
            camEnabled = false;
            var cb = document.getElementById('camBtn');
            cb.disabled = true; cb.title = 'Camera not available';
            setCamUI(false);
        }

        for (var i = 0; i < tracks.length; i++) {
            var t = tracks[i];
            await room.localParticipant.publishTrack(t);
            console.log('[CONNECT] published track:', t.sid, t.kind);
            if (t.kind === 'video') {
                t.attach(document.getElementById('mainVideo'));
                document.getElementById('mainVideo').style.display = 'block';
                document.getElementById('mainVideo').className = 'mirrored';
                document.getElementById('mainAvatar').style.display = 'none';
            }
        }

        buildLocalSidebarTile();
        tryEnableNoiseFilter();
        console.log('[CONNECT] start() completed successfully');

    } catch(err) {
        console.log('[CONNECT] start() catch:', err.name, err.message);
        setStatus('error');
        showToast('Error: ' + err.message, 5000);
    }
}

// ── Noise filter (Krisp) ──────────────────────────────────────────────────────
function tryEnableNoiseFilter() {
    // Only on non-low-power devices; try using SDK's noise filter if available
    try {
        var isLowPower = navigator.hardwareConcurrency && navigator.hardwareConcurrency <= 2;
        if (!isLowPower && sdk.KrispNoiseFilter && room && room.localParticipant) {
            sdk.KrispNoiseFilter.create().then(function(filter) {
                if (room && room.localParticipant) {
                    room.localParticipant.setAudioTrackProcessor(filter);
                    console.log('[MIC] Krisp noise filter enabled');
                }
            }).catch(function(e) {
                console.log('[MIC] Krisp not available:', e.message);
            });
        }
    } catch(e) {
        console.log('[MIC] Noise filter init skipped:', e.message);
    }
}

// ── Audio management ─────────────────────────────────────────────────────────
var remoteAudioElements = {};

function attachRemoteAudio(participant, track) {
    if (!participant) return;
    var id = participant.identity;
    // Detach old if any
    detachRemoteAudio(id);
    var a = document.createElement('audio');
    a.autoplay = true;
    a.id = 'audio_' + id;
    document.getElementById('audioElements').appendChild(a);
    track.attach(a);
    a.play().catch(function(){});
    remoteAudioElements[id] = a;
}

function detachRemoteAudio(id) {
    if (remoteAudioElements[id]) {
        remoteAudioElements[id].remove();
        delete remoteAudioElements[id];
    }
}

// ── Device selectors ──────────────────────────────────────────────────────────
async function populateDeviceSelectors() {
    try {
        var devices = await navigator.mediaDevices.enumerateDevices();
        var cams = devices.filter(function(d){ return d.kind === 'videoinput'; });
        var mics = devices.filter(function(d){ return d.kind === 'audioinput'; });
        var spks = devices.filter(function(d){ return d.kind === 'audiooutput'; });

        function populate(sel, devs) {
            sel.innerHTML = '';
            devs.forEach(function(d, i) {
                var opt = document.createElement('option');
                opt.value = d.deviceId;
                opt.textContent = d.label || ('Device ' + (i+1));
                sel.appendChild(opt);
            });
            if (devs.length === 0) {
                var opt = document.createElement('option');
                opt.textContent = 'No devices found'; sel.appendChild(opt);
            }
        }

        populate(document.getElementById('camSelect'), cams);
        populate(document.getElementById('micSelect'), mics);
        populate(document.getElementById('speakerSelect'), spks);
    } catch(e) {
        console.log('[SETTINGS] Could not enumerate devices:', e.message);
    }
}

async function switchCamera(deviceId) {
    if (!room || !room.localParticipant || !deviceId) return;
    try {
        await room.switchActiveDevice('videoinput', deviceId);
        showToast('Camera switched');
    } catch(e) { showToast('Could not switch camera: ' + e.message); }
}

async function switchMic(deviceId) {
    if (!room || !room.localParticipant || !deviceId) return;
    try {
        await room.switchActiveDevice('audioinput', deviceId);
        showToast('Microphone switched');
    } catch(e) { showToast('Could not switch mic: ' + e.message); }
}

async function switchSpeaker(deviceId) {
    if (!deviceId) return;
    // Apply to all audio elements
    Object.values(remoteAudioElements).forEach(function(a) {
        if (a.setSinkId) { a.setSinkId(deviceId).catch(function(){}); }
    });
    showToast('Speaker switched');
}

// ── Background ────────────────────────────────────────────────────────────────
function setBg(type, el) {
    document.querySelectorAll('.bg-option').forEach(function(o){ o.classList.remove('selected'); });
    el.classList.add('selected');
    currentBg = type;

    if (!sdk || !room || !room.localParticipant) return;
    try {
        if (type === 'none') {
            if (sdk.BackgroundBlur) {
                room.localParticipant.getTrackPublication(sdk.Track.Source.Camera)
                    ?.track?.stopProcessor?.();
            }
        } else if (type === 'blur') {
            if (sdk.BackgroundBlur) {
                var processor = sdk.BackgroundBlur(10, { delegate: 'GPU' });
                var pub = room.localParticipant.getTrackPublication(sdk.Track.Source.Camera);
                if (pub && pub.track) { pub.track.setProcessor(processor); }
            } else { showToast('Background blur not available in this SDK version'); }
        } else if (type === 'office' || type === 'nature') {
            if (sdk.VirtualBackground) {
                // Use a solid color as virtual background (no external image needed)
                var colors = { office: '#1a2340', nature: '#1a3325' };
                var processor = sdk.VirtualBackground({ blurRadius: 0, imagePath: null });
                var pub = room.localParticipant.getTrackPublication(sdk.Track.Source.Camera);
                if (pub && pub.track) { pub.track.setProcessor(processor); }
            } else { showToast('Virtual background not available in this SDK version'); }
        }
    } catch(e) {
        console.log('[BG] Background processor error:', e.message);
        showToast('Background effect not supported');
    }
}

// ── Participant count & list ───────────────────────────────────────────────────
function updateParticipantCount() {
    var remoteCount = 0;
    if (room && room.remoteParticipants) { remoteCount = room.remoteParticipants.size; }
    else { remoteCount = Object.keys(remoteParticipants).length; }
    var count = 1 + remoteCount;
    var el = document.getElementById('participantCount');
    if (el) el.innerText = count;
    var badge = document.getElementById('drawerCountBadge');
    if (badge) badge.innerText = count;
}

function renderParticipantList() {
    var list = document.getElementById('participantList');
    list.innerHTML = '';

    // Self first
    var selfName = (room && room.localParticipant && room.localParticipant.identity)
        ? room.localParticipant.identity : 'You';
    var selfSpeaking = activeSpeakers.has(selfName);
    var selfItem = makeParticipantItem(selfName, !micEnabled, true, selfSpeaking);
    list.appendChild(selfItem);

    // Remote participants
    Object.keys(remoteParticipants).forEach(function(id) {
        var p = remoteParticipants[id];
        var item = makeParticipantItem(p.name, p.micMuted, false, p.speaking);
        list.appendChild(item);
    });
}

function makeParticipantItem(name, isMuted, isSelf, isSpeaking) {
    var item = document.createElement('div');
    item.className = 'p-item';

    var av = document.createElement('div');
    av.className = 'p-avatar' + (isSpeaking ? ' speaking' : '');
    av.innerText = name.charAt(0).toUpperCase();
    var dot = document.createElement('div');
    dot.className = 'p-speaking-dot';
    av.appendChild(dot);
    item.appendChild(av);

    var nameWrap = document.createElement('div');
    nameWrap.style.cssText = 'flex:1; overflow:hidden;';
    var nameEl = document.createElement('div');
    nameEl.className = 'p-name';
    nameEl.innerText = name;
    if (isSelf) {
        var tag = document.createElement('span');
        tag.className = 'p-you-tag'; tag.innerText = 'You';
        nameEl.appendChild(tag);
    }
    nameWrap.appendChild(nameEl);
    item.appendChild(nameWrap);

    var micEl = document.createElement('div');
    micEl.className = 'p-mic-icon' + (isMuted ? ' muted' : '');
    if (isMuted) {
        micEl.innerHTML = '<svg viewBox="0 0 24 24"><path d="M19 11h-1.7c0 .74-.16 1.43-.43 2.05l1.23 1.23c.56-.98.9-2.09.9-3.28zm-4.02.17c0-.06.02-.11.02-.17V5c0-1.66-1.34-3-3-3S9 3.34 9 5v.18l5.98 5.99zM4.27 3 3 4.27l6.01 6.01V11c0 1.66 1.33 3 2.99 3 .22 0 .44-.03.65-.08l1.66 1.66c-.71.33-1.5.52-2.31.52-2.76 0-5.3-2.1-5.3-5.1H5c0 3.41 2.72 6.23 6 6.72V21h2v-3.28c.91-.13 1.77-.45 2.54-.9L19.73 21 21 19.73 4.27 3z"/></svg>';
    } else {
        micEl.innerHTML = '<svg viewBox="0 0 24 24"><path d="M12 14c1.66 0 3-1.34 3-3V5c0-1.66-1.34-3-3-3S9 3.34 9 5v6c0 1.66 1.34 3 3 3zm5.3-3c0 3-2.54 5.1-5.3 5.1S6.7 14 6.7 11H5c0 3.41 2.72 6.23 6 6.72V21h2v-3.28c3.28-.49 6-3.31 6-6.72h-1.7z"/></svg>';
    }
    item.appendChild(micEl);
    return item;
}

// ── Drawer ────────────────────────────────────────────────────────────────────
function toggleDrawer() {
    var drawer = document.getElementById('participantDrawer');
    var overlay = document.getElementById('drawerOverlay');
    if (drawer.classList.contains('open')) {
        closeDrawer();
    } else {
        closeSettings();
        renderParticipantList();
        drawer.classList.add('open');
        overlay.classList.add('open');
    }
}

function closeDrawer() {
    document.getElementById('participantDrawer').classList.remove('open');
    document.getElementById('drawerOverlay').classList.remove('open');
}

// ── Settings ──────────────────────────────────────────────────────────────────
function toggleSettings() {
    var drawer = document.getElementById('settingsDrawer');
    if (drawer.classList.contains('open')) {
        closeSettings();
    } else {
        closeDrawer();
        drawer.classList.add('open');
        settingsOpen = true;
        populateDeviceSelectors();
    }
}

function closeSettings() {
    document.getElementById('settingsDrawer').classList.remove('open');
    settingsOpen = false;
}

function switchSettTab(tabId, btn) {
    document.querySelectorAll('.sett-tab').forEach(function(t){ t.classList.remove('active'); });
    document.querySelectorAll('.sett-section').forEach(function(s){ s.classList.remove('active'); });
    btn.classList.add('active');
    document.getElementById('sett-' + tabId).classList.add('active');
}

// ── Sidebar management ────────────────────────────────────────────────────────
function addParticipantTile(p) {
    var id = p.identity;
    if (document.getElementById('s_' + id)) return;

    var tile = makeSidebarTile('s_' + id, id, false);
    tile.onclick = function(){ pinParticipant(id); };

    var muteEl = document.createElement('div');
    muteEl.className = 's-tile-muted'; muteEl.id = 'smute_' + id;
    muteEl.innerHTML = '<svg viewBox="0 0 24 24"><path d="M19 11h-1.7c0 .74-.16 1.43-.43 2.05l1.23 1.23c.56-.98.9-2.09.9-3.28zm-4.02.17c0-.06.02-.11.02-.17V5c0-1.66-1.34-3-3-3S9 3.34 9 5v.18l5.98 5.99zM4.27 3 3 4.27l6.01 6.01V11c0 1.66 1.33 3 2.99 3 .22 0 .44-.03.65-.08l1.66 1.66c-.71.33-1.5.52-2.31.52-2.76 0-5.3-2.1-5.3-5.1H5c0 3.41 2.72 6.23 6 6.72V21h2v-3.28c.91-.13 1.77-.45 2.54-.9L19.73 21 21 19.73 4.27 3z"/></svg>';
    tile.appendChild(muteEl);

    document.getElementById('sidebar').appendChild(tile);
    remoteTracks[id] = { name: id, tileEl: tile };

    if (pinnedId === 'local') { pinParticipant(id); }
}

function removeParticipantTile(id) {
    var data = remoteTracks[id];
    if (data && data.tileEl) { data.tileEl.remove(); }
    delete remoteTracks[id];
    if (pinnedId === id) pinParticipant('local');
}

function updateParticipantVideo(p, track) {
    if (!p) return;
    var id = p.identity;
    console.log('[PIN] incoming video track - identity:', id, 'source:', track.source);
    var data = remoteTracks[id];
    if (!data) { addParticipantTile(p); data = remoteTracks[id]; }
    if (!data) return;

    // Remove old video
    var oldV = data.tileEl.querySelector('video');
    if (oldV) oldV.remove();

    var v = document.createElement('video');
    v.autoplay = true; v.playsinline = true;
    v.style.cssText = 'width:100%;height:100%;object-fit:cover;display:block;';
    track.attach(v);
    data.tileEl.insertBefore(v, data.tileEl.firstChild);
    data.tileEl.classList.add('has-video');
    data.track = track;
    data.videoEl = v;
    data.isScreen = (track.source === 'screen_share' || (sdk.Track && track.source === sdk.Track.Source.ScreenShare));

    if (data.isScreen) {
        if (!data.tileEl.querySelector('.s-screen-badge')) {
            var sb = document.createElement('div');
            sb.className = 's-screen-badge'; sb.innerText = '● Screen';
            data.tileEl.appendChild(sb);
        }
        pinParticipant(id);
    } else if (pinnedId === id) {
        var mainVideo = document.getElementById('mainVideo');
        track.attach(mainVideo);
        mainVideo.style.display = 'block';
        mainVideo.className = 'unmirrored';
        document.getElementById('mainAvatar').style.display = 'none';
        mainVideo.play().catch(function(){});
    }
}

function clearParticipantVideo(p) {
    if (!p) return;
    var id = p.identity;
    var data = remoteTracks[id];
    if (data && data.tileEl) {
        var v = data.tileEl.querySelector('video');
        if (v) v.remove();
        data.tileEl.classList.remove('has-video');
        delete data.track; delete data.videoEl;
    }
    if (pinnedId === id) {
        document.getElementById('mainVideo').style.display = 'none';
        document.getElementById('mainAvatar').style.display = 'flex';
    }
}

// ── Build local sidebar tile ──────────────────────────────────────────────────
function buildLocalSidebarTile() {
    if (document.getElementById('s_local')) return;
    var tile = makeSidebarTile('s_local', 'You', false);
    tile.classList.add('mirrored');
    tile.onclick = function(){ pinParticipant('local'); };

    var muteEl = document.createElement('div');
    muteEl.className = 's-tile-muted'; muteEl.id = 's_local_muted';
    muteEl.innerHTML = '<svg viewBox="0 0 24 24"><path d="M19 11h-1.7c0 .74-.16 1.43-.43 2.05l1.23 1.23c.56-.98.9-2.09.9-3.28zm-4.02.17c0-.06.02-.11.02-.17V5c0-1.66-1.34-3-3-3S9 3.34 9 5v.18l5.98 5.99zM4.27 3 3 4.27l6.01 6.01V11c0 1.66 1.33 3 2.99 3 .22 0 .44-.03.65-.08l1.66 1.66c-.71.33-1.5.52-2.31.52-2.76 0-5.3-2.1-5.3-5.1H5c0 3.41 2.72 6.23 6 6.72V21h2v-3.28c.91-.13 1.77-.45 2.54-.9L19.73 21 21 19.73 4.27 3z"/></svg>';
    tile.appendChild(muteEl);

    if (camEnabled) {
        var v = document.createElement('video');
        v.autoplay = true; v.muted = true; v.playsinline = true;
        v.style.cssText = 'width:100%;height:100%;object-fit:cover;display:block;';
        var mainV = document.getElementById('mainVideo');
        if (mainV.srcObject) { v.srcObject = mainV.srcObject; tile.classList.add('has-video'); }
        tile.insertBefore(v, tile.firstChild);
    }

    document.getElementById('sidebar').appendChild(tile);
    if (pinnedId === 'local') { tile.classList.add('pinned'); }
}

// ── Sidebar tile factory ──────────────────────────────────────────────────────
function makeSidebarTile(id, name, isScreen) {
    var tile = document.createElement('div');
    tile.className = 's-tile'; tile.id = id;
    var avEl = document.createElement('div');
    avEl.className = 's-tile-avatar'; avEl.innerText = name.charAt(0).toUpperCase();
    tile.appendChild(avEl);
    if (isScreen) {
        var sb = document.createElement('div');
        sb.className = 's-screen-badge'; sb.innerText = '● Screen';
        tile.appendChild(sb);
    }
    var lbl = document.createElement('div');
    lbl.className = 's-tile-label'; lbl.innerText = name + (isScreen ? ' · Screen' : '');
    tile.appendChild(lbl);
    var hint = document.createElement('div');
    hint.className = 's-tile-hint'; hint.innerText = pinnedId === id.replace(/^s_/,'') ? 'Unpin' : 'Pin';
    tile.appendChild(hint);
    return tile;
}

// ── Pin ───────────────────────────────────────────────────────────────────────
function pinParticipant(id) {
    var name = (id === 'local') ? (room && room.localParticipant ? room.localParticipant.identity : 'You') : (remoteTracks[id] ? remoteTracks[id].name : 'Unknown');
    console.log('[PIN] pinParticipant called with id:', id, 'name:', name);
    var prevPinned = pinnedId;
    pinnedId = id;
    document.querySelectorAll('.s-tile').forEach(function(t){ t.classList.remove('pinned'); });

    var mainVideo   = document.getElementById('mainVideo');
    var mainAvatar  = document.getElementById('mainAvatar');
    var mainLblText = document.getElementById('mainLabelText');
    var mainMuted   = document.getElementById('mainMutedBadge');
    var screenBadge = document.getElementById('mainScreenBadge');
    var mainView    = document.getElementById('mainView');

    mainAvatar.style.display  = 'none';
    mainVideo.style.display   = 'none';
    screenBadge.style.display = 'none';
    mainMuted.classList.remove('show');
    mainView.classList.remove('speaking');
    
    // Explicitly clear srcObject to ensure a fresh track attachment
    if (mainVideo.srcObject) { mainVideo.srcObject = null; }

    if (id === 'local') {
        mainLblText.innerText = room && room.localParticipant ? room.localParticipant.identity : 'You';
        if (room && room.localParticipant) {
            var vTracks = [];
            if (room.localParticipant.videoTracks) {
                room.localParticipant.videoTracks.forEach(function(pub) {
                    if (pub && pub.track) { vTracks.push(pub.track); }
                });
            }
            if (vTracks.length > 0 && camEnabled) {
                mainVideo.style.display = 'block';
                mainVideo.className = 'mirrored';
                vTracks[0].attach(mainVideo);
                mainVideo.play().catch(function(){});
                setTimeout(function() { console.log('[PIN] Local Video Details:', mainVideo.videoWidth + 'x' + mainVideo.videoHeight, 'ReadyState:', mainVideo.readyState); }, 500);
            } else {
                mainAvatar.style.display = 'flex';
            }
        } else {
            mainAvatar.style.display = 'flex';
        }
        if (!micEnabled) mainMuted.classList.add('show');
        var lt = document.getElementById('s_local');
        if (lt) lt.classList.add('pinned');
        // Speaking indicator
        if (room && room.localParticipant && activeSpeakers.has(room.localParticipant.identity)) {
            mainView.classList.add('speaking');
        }
    } else {
        var data = remoteTracks[id];
        if (!data) { console.warn('[PIN] No track data for sid:', id); pinParticipant('local'); return; }

        mainLblText.innerText = data.name + (data.isScreen ? ' · Screen' : '');
        if (data.isScreen) screenBadge.style.display = 'block';

        if (data.isScreenLocal && data.stream) {
            mainVideo.style.display = 'block';
            mainVideo.className = 'unmirrored';
            mainVideo.srcObject = data.stream;
            mainVideo.play().catch(function(){});
            setTimeout(function() { console.log('[PIN] Screen Share Details:', mainVideo.videoWidth + 'x' + mainVideo.videoHeight, 'ReadyState:', mainVideo.readyState); }, 500);
        } else if (data.track && typeof data.track.attach === 'function') {
            try { 
                mainVideo.style.display = 'block';
                mainVideo.className = 'unmirrored';
                data.track.attach(mainVideo); 
                mainVideo.play().catch(function(){});
                setTimeout(function() { console.log('[PIN] Remote Video Details:', mainVideo.videoWidth + 'x' + mainVideo.videoHeight, 'ReadyState:', mainVideo.readyState, 'SID:', id); }, 500);
            } catch(err) { console.error('[PIN] track.attach error:', err); }
        } else {
            console.warn('[PIN] data.track is missing or unattachable for sid:', id);
            mainAvatar.style.display = 'flex';
        }

        // Remote mic mute badge
        if (remoteParticipants[id] && remoteParticipants[id].micMuted) {
            mainMuted.classList.add('show');
        }

        var tile = document.getElementById('s_' + id);
        if (tile) tile.classList.add('pinned');

        // Speaking indicator
        if (activeSpeakers.has(id)) { mainView.classList.add('speaking'); }
    }

    // Update hint text
    document.querySelectorAll('.s-tile-hint').forEach(function(h) {
        var tileId = h.closest('.s-tile').id.replace(/^s_/, '');
        h.innerText = (tileId === id) ? 'Unpin' : 'Pin';
    });
}

// ── Mic ───────────────────────────────────────────────────────────────────────
function setMicUI(on) {
    console.log('[MIC] setMicUI:', on);
    document.getElementById('micOnIcon').style.display  = on ? 'block' : 'none';
    document.getElementById('micOffIcon').style.display = on ? 'none'  : 'block';
    document.getElementById('micLabel').innerText = on ? 'Mute' : 'Unmute';
    document.getElementById('micBtn').classList.toggle('off', !on);

    var sm = document.getElementById('s_local_muted');
    if (sm) sm.classList.toggle('show', !on);
    if (pinnedId === 'local') {
        document.getElementById('mainMutedBadge').classList.toggle('show', !on);
    }

    // Sync settings toggle
    var settToggle = document.getElementById('settMicToggle');
    if (settToggle) settToggle.checked = on;

    renderParticipantList();
}

async function toggleMic() {
    if (!room || !room.localParticipant || !micAvailable) return;
    console.log('[MIC] toggleMic, current:', micEnabled);
    micEnabled = !micEnabled;
    try {
        await room.localParticipant.setMicrophoneEnabled(micEnabled);
        console.log('[MIC] setMicrophoneEnabled resolved:', room.localParticipant.isMicrophoneEnabled);
        setMicUI(micEnabled);
        showToast(micEnabled ? 'Mic on' : 'Mic muted');
    } catch(e) {
        console.log('[MIC] toggleMic error:', e);
        micEnabled = !micEnabled;
    }
}

// ── Camera ────────────────────────────────────────────────────────────────────
// setCamUI is called AFTER setCameraEnabled resolves so the fresh track is published.
function setCamUI(on) {
    document.getElementById('camOnIcon').style.display  = on ? 'block' : 'none';
    document.getElementById('camOffIcon').style.display = on ? 'none'  : 'block';
    document.getElementById('camLabel').innerText = on ? 'Stop Cam' : 'Start Cam';
    document.getElementById('camBtn').classList.toggle('off', !on);

    var settToggle = document.getElementById('settCamToggle');
    if (settToggle) settToggle.checked = on;

    var localTile = document.getElementById('s_local');

    if (!on) {
        // Camera OFF: hide video, show avatar placeholder
        if (localTile) {
            var localVid = localTile.querySelector('video');
            if (localVid) localVid.style.display = 'none';
            localTile.classList.remove('has-video');
        }
        if (pinnedId === 'local') {
            document.getElementById('mainVideo').style.display = 'none';
            document.getElementById('mainAvatar').style.display = 'flex';
        }
        return;
    }

    // Camera ON: find the fresh track (SDK has already published it at this point)
    if (!room || !room.localParticipant) return;
    var freshTrack = null;
    if (room.localParticipant.videoTracks) {
        room.localParticipant.videoTracks.forEach(function(pub) {
            if (pub && pub.track && !freshTrack) { freshTrack = pub.track; }
        });
    }
    if (!freshTrack) {
        // Still not ready — fall back to avatar
        if (pinnedId === 'local') {
            document.getElementById('mainVideo').style.display = 'none';
            document.getElementById('mainAvatar').style.display = 'flex';
        }
        return;
    }

    // Re-build sidebar video with the fresh track (removes stale srcObject)
    if (localTile) {
        var oldVid = localTile.querySelector('video');
        if (oldVid) oldVid.remove();
        var sideVid = document.createElement('video');
        sideVid.autoplay = true; sideVid.muted = true; sideVid.playsinline = true;
        sideVid.style.cssText = 'width:100%;height:100%;object-fit:cover;display:block;';
        freshTrack.attach(sideVid);
        localTile.insertBefore(sideVid, localTile.firstChild);
        localTile.classList.add('has-video');
        sideVid.play().catch(function(){});
    }

    // Re-attach to main view if local is pinned
    if (pinnedId === 'local') {
        var mainVideo = document.getElementById('mainVideo');
        freshTrack.attach(mainVideo);
        mainVideo.style.display = 'block';
        document.getElementById('mainAvatar').style.display = 'none';
        mainVideo.play().catch(function(){});
    }
}

async function toggleCam() {
    if (!room || !room.localParticipant || !camAvailable) return;
    camEnabled = !camEnabled;
    try {
        await room.localParticipant.setCameraEnabled(camEnabled);
        // setCameraEnabled resolves only after the new track is published —
        // safe to read videoTracks now.
        setCamUI(camEnabled);
        showToast(camEnabled ? 'Camera on' : 'Camera off');
    } catch(e) { camEnabled = !camEnabled; console.error(e); }
}

// ── Screen share ──────────────────────────────────────────────────────────────
function setScreenUI(on) {
    document.getElementById('screenLabel').innerText = on ? 'Stop Sharing' : 'Share Screen';
    document.getElementById('screenBtn').classList.toggle('screen-on', on);
}

async function toggleScreen() {
    if (!room || !room.localParticipant) return;

    if (screenTrack) {
        try { await room.localParticipant.unpublishTrack(screenTrack); screenTrack.stop(); } catch(e){}
        if (screenSid) {
            var el = document.getElementById('s_' + screenSid);
            if (el) el.remove();
            if (pinnedId === screenSid) pinParticipant('local');
            delete remoteTracks[screenSid];
            screenSid = null;
        }
        screenTrack = null;
        setScreenUI(false);
        showToast('Screen sharing stopped');
        return;
    }

    try {
        var stream = await navigator.mediaDevices.getDisplayMedia({ video:true, audio:false });
        var mediaTrack = stream.getVideoTracks()[0];

        mediaTrack.addEventListener('ended', function() {
            if (screenTrack) { toggleScreen(); }
        });

        var lsTrack = new sdk.LocalVideoTrack(mediaTrack);
        await room.localParticipant.publishTrack(lsTrack, {
            source: sdk.Track && sdk.Track.Source ? sdk.Track.Source.ScreenShare : 'screen_share'
        });

        screenTrack = lsTrack;
        var sid = 'screen_' + Date.now();
        screenSid = sid;

        var tile = makeSidebarTile('s_' + sid, 'Your Screen', true);
        tile.onclick = function(){ pinParticipant(sid); };

        var v = document.createElement('video');
        v.autoplay = true; v.muted = true; v.playsinline = true;
        v.style.cssText = 'width:100%;height:100%;object-fit:cover;display:block;';
        v.srcObject = stream;
        tile.insertBefore(v, tile.firstChild);
        tile.classList.add('has-video');

        document.getElementById('sidebar').appendChild(tile);

        remoteTracks[sid] = {
            track: lsTrack, name: 'Your Screen', isScreen: true,
            isScreenLocal: true, stream: stream, tileEl: tile, videoEl: v
        };

        pinParticipant(sid);
        setScreenUI(true);
        showToast('Screen sharing started');
    } catch(e) {
        if (e.name !== 'NotAllowedError') {
            showToast('Screen share failed: ' + e.message, 4000);
        }
    }
}

// ── End call ──────────────────────────────────────────────────────────────────
function handleEndClick() {
    if (isHost) {
        document.getElementById('endCallModalOverlay').classList.add('open');
    } else {
        endCall();
    }
}

function closeEndModal() {
    document.getElementById('endCallModalOverlay').classList.remove('open');
}

async function doLeaveCall() {
    closeEndModal();
    stopRecordingIfNeeded();
    if (screenTrack) { try { screenTrack.stop(); await room.localParticipant.unpublishTrack(screenTrack); } catch(e){} }
    if (room) { try { await room.disconnect(); } catch(e){} room = null; }
    clearInterval(timerInterval);
    endCallScreen();
}

async function doEndForAll() {
    closeEndModal();
    stopRecordingIfNeeded();
    if (room && room.localParticipant) {
        try {
            var msg = JSON.stringify({ action: 'endForAll' });
            await room.localParticipant.publishData(new TextEncoder().encode(msg), { reliable: true });
        } catch(e) { console.error('[END] Failed to send endForAll:', e); }
    }
    setTimeout(async function() {
        if (screenTrack) { try { screenTrack.stop(); await room.localParticipant.unpublishTrack(screenTrack); } catch(e){} }
        if (room) { try { await room.disconnect(); } catch(e){} room = null; }
        clearInterval(timerInterval);
        endCallScreen();
    }, 400);
}

async function endCall() {
    stopRecordingIfNeeded();
    if (screenTrack) { try { screenTrack.stop(); await room.localParticipant.unpublishTrack(screenTrack); } catch(e){} }
    if (room) { try { await room.disconnect(); } catch(e){} room = null; }
    clearInterval(timerInterval);
    window.close();
    setTimeout(endCallScreen, 300);
}

function endCallScreen() {
    window.close();
    setTimeout(function() {
        document.body.innerHTML = '<div style="display:flex;align-items:center;justify-content:center;height:100vh;font-family:DM Sans,sans-serif;color:#6b7280;font-size:14px;background:#0a0b0d;letter-spacing:.02em;">Call ended — you can close this tab.</div>';
    }, 300);
}

// ── Keyboard shortcuts ────────────────────────────────────────────────────────
document.addEventListener('keydown', function(e) {
    if (e.target.tagName === 'INPUT' || e.target.tagName === 'SELECT' || e.target.tagName === 'TEXTAREA') return;

    var isMac = navigator.platform.indexOf('Mac') !== -1;
    var mod = isMac ? e.metaKey : e.ctrlKey;

    // Ctrl/Cmd + Shift + A → toggle mic
    if (mod && e.shiftKey && (e.key === 'A' || e.key === 'a')) {
        e.preventDefault(); toggleMic(); return;
    }
    // Ctrl/Cmd + Shift + V → toggle camera
    if (mod && e.shiftKey && (e.key === 'V' || e.key === 'v')) {
        e.preventDefault(); toggleCam(); return;
    }

    if (e.key === 'Escape') {
        // Close open panels first
        if (document.getElementById('endCallModalOverlay').classList.contains('open')) {
            closeEndModal(); return;
        }
        if (settingsOpen) { closeSettings(); return; }
        if (document.getElementById('participantDrawer').classList.contains('open')) {
            closeDrawer(); return;
        }
        handleEndClick();
    }
});
</script>
