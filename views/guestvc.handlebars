        }
        #participantPill:hover { background: var(--surface3); border-color: var(--border2); color: var(--text); }
        #participantPill svg { width: 14px; height: 14px; fill: currentColor; flex-shrink: 0; }
        #participantCount { font-family: 'DM Mono', monospace; }

        /* ── PARTICIPANT DRAWER ────────────────────────────── */
        #drawerOverlay {
            position: fixed; inset: 0;
            background: rgba(0,0,0,0.35);
            z-index: 100;
            opacity: 0; pointer-events: none;
            transition: opacity 0.22s;
        }
        #drawerOverlay.open { opacity: 1; pointer-events: all; }

        #participantDrawer {
            position: fixed; top: 0; right: 0; bottom: 0;
            width: 280px;
            background: var(--surface);
            border-left: 1px solid var(--border2);
            z-index: 101;
            display: flex; flex-direction: column;
            transform: translateX(100%);
            transition: transform 0.25s cubic-bezier(0.4,0,0.2,1);
            box-shadow: -8px 0 32px rgba(0,0,0,0.5);
        }
        #participantDrawer.open { transform: translateX(0); }

        #drawerHeader {
            padding: 16px 18px;
            border-bottom: 1px solid var(--border);
            display: flex; align-items: center; justify-content: space-between;
            flex-shrink: 0;
        }
        #drawerTitle {
            font-size: 14px; font-weight: 600; color: var(--text);
            display: flex; align-items: center; gap: 7px;
        }
        #drawerTitle svg { width: 16px; height: 16px; fill: var(--text-mid); }
        #drawerCountBadge {
            font-size: 11px; font-weight: 600;
            background: var(--surface3);
            border: 1px solid var(--border2);
            color: var(--text-mid);
            padding: 1px 7px; border-radius: 10px;
            font-family: 'DM Mono', monospace;
        }
        #drawerCloseBtn {
            width: 28px; height: 28px; border-radius: 7px;
            background: none; border: none; cursor: pointer;
            display: flex; align-items: center; justify-content: center;
            color: var(--text-dim);
            transition: background 0.15s, color 0.15s;
        }
        #drawerCloseBtn:hover { background: var(--surface3); color: var(--text); }
        #drawerCloseBtn svg { width: 16px; height: 16px; fill: currentColor; }

        #participantList {
            flex: 1; overflow-y: auto; padding: 10px 0;
            scrollbar-width: thin;
            scrollbar-color: var(--surface3) transparent;
        }
        #participantList::-webkit-scrollbar { width: 3px; }
        #participantList::-webkit-scrollbar-thumb { background: var(--surface3); border-radius: 3px; }

        .p-item {
            display: flex; align-items: center; gap: 10px;
            padding: 9px 18px;
            transition: background 0.12s;
        }
        .p-item:hover { background: var(--surface2); }

        .p-avatar {
            width: 34px; height: 34px; border-radius: 50%;
            background: var(--surface3);
            border: 1px solid var(--border2);
            display: flex; align-items: center; justify-content: center;
            font-size: 13px; font-weight: 600; color: var(--text-mid);
            flex-shrink: 0;
        }

        .p-name {
            flex: 1; font-size: 13px; font-weight: 500; color: var(--text);
            overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
        }
        .p-you-tag {
            font-size: 10px; color: var(--text-dim);
            background: var(--surface3);
            padding: 1px 6px; border-radius: 6px;
            margin-left: 4px;
        }

        .p-mic-icon { width: 16px; height: 16px; flex-shrink: 0; }
        .p-mic-icon svg { width: 16px; height: 16px; fill: var(--text-dim); }
        .p-mic-icon.muted svg { fill: var(--red); }

        /* ── BODY ────────────────────────────────────────────── */
        #callBody {
            flex: 1; display: flex; overflow: hidden;
            background: #000; gap: 3px; padding: 3px;
        }

        /* ── MAIN VIEW ───────────────────────────────────────── */
        #mainView {
            flex: 1; position: relative;
            border-radius: var(--radius); overflow: hidden;
            background: var(--surface);
            display: flex; align-items: center; justify-content: center;
        }
        #mainVideo { width:100%; height:100%; object-fit:cover; display:block; }

        #mainAvatar {
            width: 88px; height: 88px; border-radius: 50%;
            background: var(--surface3);
            border: 2px solid var(--border2);
            display: none; align-items: center; justify-content: center;
            font-size: 32px; font-weight: 600; color: var(--text-mid);
            position: absolute;
        }

        #mainLabel {
            position: absolute; bottom: 14px; left: 14px;
            font-size: 13px; font-weight: 500; color: #fff;
            background: rgba(0,0,0,0.55);
            backdrop-filter: blur(10px);
            padding: 5px 12px; border-radius: 20px;
            border: 1px solid rgba(255,255,255,0.08);
            display: flex; align-items: center; gap: 6px;
            pointer-events: none;
        }

        #mainMutedBadge { display:none; align-items:center; justify-content:center; }
        #mainMutedBadge.show { display:flex; }
        #mainMutedBadge svg { width:14px; height:14px; fill:var(--red); }

        #mainScreenBadge {
            position: absolute; top: 13px; left: 13px;
            font-size: 10px; font-weight: 700; letter-spacing: 0.07em;
            text-transform: uppercase; color: var(--accent);
            background: var(--accent-glow);
            border: 1px solid rgba(59,130,246,0.4);
            padding: 3px 10px; border-radius: 20px;
            display: none; pointer-events: none;
        }

        /* ── SIDEBAR ─────────────────────────────────────────── */
        #sidebar {
            width: 214px; flex-shrink: 0;
            display: flex; flex-direction: column; gap: 3px;
            overflow-y: auto;
            scrollbar-width: thin;
            scrollbar-color: var(--surface3) transparent;
        }
        #sidebar::-webkit-scrollbar { width: 3px; }
        #sidebar::-webkit-scrollbar-thumb { background: var(--surface3); border-radius: 3px; }

        .s-tile {
            flex-shrink: 0; height: 144px;
            border-radius: var(--radius-sm);
            background: var(--surface);
            position: relative; overflow: hidden;
            cursor: pointer;
            border: 2px solid transparent;
            transition: border-color 0.18s, transform 0.15s;
            display: flex; align-items: center; justify-content: center;
        }
        .s-tile:hover { border-color: var(--border2); transform: scale(1.015); }
        .s-tile.pinned { border-color: var(--accent); }
        .s-tile video { width:100%; height:100%; object-fit:cover; display:block; }

        .s-tile-avatar {
            width: 44px; height: 44px; border-radius: 50%;
            background: var(--surface3);
            display: flex; align-items: center; justify-content: center;
            font-size: 17px; font-weight: 600; color: var(--text-mid);
            position: absolute;
        }

        /* Fix: hide avatar when video is showing */
        .s-tile.has-video .s-tile-avatar { display: none; }

        .s-tile-label {
            position: absolute; bottom: 6px; left: 7px;
            font-size: 11px; font-weight: 500; color: #fff;
            background: rgba(0,0,0,0.6);
            backdrop-filter: blur(6px);
            padding: 2px 7px; border-radius: 9px;
            max-width: 130px; overflow: hidden;
            text-overflow: ellipsis; white-space: nowrap;
            pointer-events: none;
        }

        .s-tile-muted {
            position: absolute; bottom: 6px; right: 6px;
            width: 20px; height: 20px; border-radius: 50%;
            background: rgba(0,0,0,0.6);
            display: none; align-items: center; justify-content: center;
        }
        .s-tile-muted.show { display:flex; }
        .s-tile-muted svg { width:11px; height:11px; fill:var(--red); }

        .s-tile-hint {
            position: absolute; top: 50%; left: 50%;
            transform: translate(-50%,-50%);
            background: rgba(0,0,0,0.72); color:#fff;
            font-size: 11px; font-weight: 500;
            padding: 3px 9px; border-radius: 9px;
            opacity: 0; transition: opacity 0.18s; pointer-events: none;
        }
        .s-tile:hover .s-tile-hint { opacity: 1; }

        /* Screen badge inside sidebar tile */
        .s-screen-badge {
            position: absolute; top: 6px; left: 7px;
            font-size: 9px; font-weight: 700; letter-spacing: .06em;
            text-transform: uppercase; color: var(--accent);
            background: var(--accent-glow);
            border: 1px solid rgba(59,130,246,0.35);
            padding: 2px 6px; border-radius: 8px;
            pointer-events: none;
        }

        /* ── CONTROLS ────────────────────────────────────────── */
        #controls {
            height: 76px;
            background: var(--bg);
            border-top: 1px solid var(--border);
            display: flex; align-items: center; justify-content: center;
            gap: 6px; flex-shrink: 0; padding: 0 10px;
        }

        .ctrl-btn {
            display: flex; flex-direction: column;
            align-items: center; gap: 4px;
            background: none; border: none; cursor: pointer;
            font-family: 'DM Sans', sans-serif;
            font-size: 10px; font-weight: 500; color: var(--text-dim);
            padding: 4px 8px; border-radius: var(--radius-sm);
            transition: color 0.15s;
            letter-spacing: 0.02em;
        }
        .ctrl-btn:hover { color: var(--text); }
        .ctrl-btn:disabled { opacity: 0.28; cursor: not-allowed; }

        .ctrl-icon {
            width: 44px; height: 44px; border-radius: 50%;
            background: var(--surface2);
            border: 1px solid var(--border);
            display: flex; align-items: center; justify-content: center;
            transition: background 0.15s, border-color 0.15s, transform 0.1s;
        }
        .ctrl-btn:hover:not(:disabled) .ctrl-icon {
            background: var(--surface3); border-color: var(--border2);
        }
        .ctrl-btn:active:not(:disabled) .ctrl-icon { transform: scale(0.92); }
        .ctrl-icon svg { width: 20px; height: 20px; fill: var(--text-mid); transition: fill 0.15s; }

        .ctrl-btn.off .ctrl-icon { background: var(--red-dim); border-color: rgba(239,68,68,0.28); }
        .ctrl-btn.off .ctrl-icon svg { fill: var(--red); }
        .ctrl-btn.off { color: var(--red); }

        .ctrl-btn.screen-on .ctrl-icon { background: var(--accent-glow); border-color: rgba(59,130,246,0.38); }
        .ctrl-btn.screen-on .ctrl-icon svg { fill: var(--accent); }
        .ctrl-btn.screen-on { color: var(--accent); }

        .ctrl-sep { width:1px; height:26px; background:var(--border); margin:0 2px; flex-shrink:0; }

        .ctrl-btn.end-call .ctrl-icon {
            width: 50px; height: 50px;
            background: var(--red); border-color: transparent;
            animation: ring 2.5s ease-in-out infinite;
        }
        @keyframes ring {
            0%,100%{ box-shadow: 0 0 0 0 rgba(239,68,68,0.4); }
            50%     { box-shadow: 0 0 0 7px rgba(239,68,68,0); }
        }
        .ctrl-btn.end-call .ctrl-icon svg { fill:#fff; width:21px; height:21px; }
        .ctrl-btn.end-call { color: var(--red); }
        .ctrl-btn.end-call:hover .ctrl-icon { background:#dc2626; animation:none; }

        /* ── JOIN OVERLAY ────────────────────────────────────── */
        #joinOverlay {
            position: fixed; inset: 0;
            background: var(--bg); z-index: 200;
            display: flex; align-items: center; justify-content: center;
        }

        #joinCard {
            background: var(--surface);
            border: 1px solid var(--border2);
            border-radius: 20px; padding: 28px;
            display: flex; flex-direction: column;
            align-items: center; gap: 18px;
            width: 380px;
            box-shadow: 0 28px 60px rgba(0,0,0,0.7);
        }

        #previewWrap {
            width: 100%; height: 196px; border-radius: var(--radius);
            overflow: hidden; background: var(--surface2);
            position: relative;
            display: flex; align-items: center; justify-content: center;
        }
        #previewVideo { width:100%; height:100%; object-fit:cover; transform:scaleX(-1); }
        #previewNoCamera {
            display:none; flex-direction:column;
            align-items:center; gap:8px;
            color: var(--text-dim); font-size:13px;
        }
        #previewNoCamera svg { width:30px; height:30px; fill:var(--text-dim); opacity:.35; }

        #joinCard h2 { font-size: 21px; font-weight: 600; }
        #joinCard p  { font-size: 13px; color: var(--text-dim); text-align:center; line-height:1.5; }

        #joinBtn {
            width: 100%; background: var(--accent); color: #fff;
            border: none; padding: 12px;
            border-radius: var(--radius);
            font-size: 15px; font-family:'DM Sans',sans-serif;
            font-weight: 600; cursor: pointer;
            transition: background 0.2s, transform 0.1s;
            box-shadow: 0 4px 18px var(--accent-glow);
        }
        #joinBtn:hover { background: #2563eb; }
        #joinBtn:active { transform: scale(0.98); }

        /* ── TOAST ───────────────────────────────────────────── */
        #toast {
            position: fixed; bottom: 88px; left: 50%;
            transform: translateX(-50%) translateY(8px);
            background: var(--surface3); color: var(--text);
            border: 1px solid var(--border2);
            padding: 8px 16px; border-radius: 9px;
            font-size: 13px; font-weight: 500;
            opacity: 0; pointer-events: none;
            transition: opacity 0.2s, transform 0.2s;
            z-index: 300; white-space: nowrap;
            box-shadow: 0 8px 24px rgba(0,0,0,0.5);
        }
        #toast.show { opacity:1; transform: translateX(-50%) translateY(0); }

        /* ── END CALL MODAL ──────────────────────────────────── */
        #endCallModalOverlay {
            position: fixed; inset: 0;
            background: rgba(0,0,0,0.6);
            z-index: 400;
            display: flex; align-items: center; justify-content: center;
            opacity: 0; pointer-events: none;
            transition: opacity 0.18s;
        }
        #endCallModalOverlay.open { opacity: 1; pointer-events: all; }

        #endCallModal {
            background: var(--surface);
            border: 1px solid var(--border2);
            border-radius: 16px;
            padding: 24px;
            width: 320px;
            box-shadow: 0 24px 60px rgba(0,0,0,0.7);
            transform: scale(0.96) translateY(6px);
            transition: transform 0.18s cubic-bezier(0.4,0,0.2,1);
        }
        #endCallModalOverlay.open #endCallModal { transform: scale(1) translateY(0); }

        #endCallModal h3 {
            font-size: 16px; font-weight: 600; color: var(--text);
            margin-bottom: 6px;
        }
        #endCallModal p {
            font-size: 13px; color: var(--text-dim); line-height: 1.5;
            margin-bottom: 20px;
        }

        .modal-btn-row { display: flex; flex-direction: column; gap: 8px; }

        .modal-btn {
            width: 100%; padding: 11px 16px;
            border-radius: var(--radius-sm);
            border: 1px solid var(--border2);
            font-family: 'DM Sans', sans-serif;
            font-size: 14px; font-weight: 500;
            cursor: pointer;
            transition: background 0.15s, border-color 0.15s;
            text-align: left; display: flex; align-items: center; gap: 10px;
        }
        .modal-btn svg { width: 17px; height: 17px; flex-shrink: 0; }

        .modal-btn.leave {
            background: var(--surface2); color: var(--text);
        }
        .modal-btn.leave svg { fill: var(--text-mid); }
        .modal-btn.leave:hover { background: var(--surface3); border-color: var(--border2); }

        .modal-btn.end-all {
            background: var(--red-dim); color: var(--red);
            border-color: rgba(239,68,68,0.3);
        }
        .modal-btn.end-all svg { fill: var(--red); }
        .modal-btn.end-all:hover { background: rgba(239,68,68,0.22); }

        .modal-btn.cancel {
            background: none; color: var(--text-dim);
            border-color: transparent;
            font-size: 13px; text-align: center; justify-content: center;
        }
        .modal-btn.cancel:hover { color: var(--text); background: var(--surface2); }
    </style>
</head>
<body>

<!-- TOP BAR -->
<div id="topBar">
    <div id="callInfo">
        <div id="statusPill" class="connecting">
            <div id="statusDot"></div>
            <span id="statusText">Connecting…</span>
        </div>
        <span id="roomLabel"></span>
    </div>
    <div id="topRight">
        <button id="recordBtn" onclick="toggleRecording()" title="Recording">
            <div id="recordDot"></div>
            <span id="recordText">REC</span>
        </button>
        <span id="callTimer">0:00</span>
        <button id="participantPill" onclick="toggleDrawer()" title="Participants">
            <svg viewBox="0 0 24 24"><path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/></svg>
            <span id="participantCount">1</span>
        </button>
    </div>
</div>

<!-- CALL BODY -->
<div id="callBody">
    <div id="mainView">
        <video id="mainVideo" autoplay muted playsinline style="display:none"></video>
        <div id="mainAvatar">Y</div>
        <div id="mainScreenBadge">● Screen Share</div>
        <div id="mainLabel">
            <span id="mainLabelText">You</span>
            <div id="mainMutedBadge">
                <svg viewBox="0 0 24 24"><path d="M19 11h-1.7c0 .74-.16 1.43-.43 2.05l1.23 1.23c.56-.98.9-2.09.9-3.28zm-4.02.17c0-.06.02-.11.02-.17V5c0-1.66-1.34-3-3-3S9 3.34 9 5v.18l5.98 5.99zM4.27 3 3 4.27l6.01 6.01V11c0 1.66 1.33 3 2.99 3 .22 0 .44-.03.65-.08l1.66 1.66c-.71.33-1.5.52-2.31.52-2.76 0-5.3-2.1-5.3-5.1H5c0 3.41 2.72 6.23 6 6.72V21h2v-3.28c.91-.13 1.77-.45 2.54-.9L19.73 21 21 19.73 4.27 3z"/></svg>
            </div>
        </div>
    </div>
    <div id="sidebar"></div>
</div>

<!-- CONTROLS -->
<div id="controls">
    <button class="ctrl-btn" id="micBtn" onclick="toggleMic()" title="Microphone (D)">
        <div class="ctrl-icon">
            <svg id="micOnIcon" viewBox="0 0 24 24"><path d="M12 14c1.66 0 3-1.34 3-3V5c0-1.66-1.34-3-3-3S9 3.34 9 5v6c0 1.66 1.34 3 3 3zm5.3-3c0 3-2.54 5.1-5.3 5.1S6.7 14 6.7 11H5c0 3.41 2.72 6.23 6 6.72V21h2v-3.28c3.28-.49 6-3.31 6-6.72h-1.7z"/></svg>
            <svg id="micOffIcon" viewBox="0 0 24 24" style="display:none"><path d="M19 11h-1.7c0 .74-.16 1.43-.43 2.05l1.23 1.23c.56-.98.9-2.09.9-3.28zm-4.02.17c0-.06.02-.11.02-.17V5c0-1.66-1.34-3-3-3S9 3.34 9 5v.18l5.98 5.99zM4.27 3 3 4.27l6.01 6.01V11c0 1.66 1.33 3 2.99 3 .22 0 .44-.03.65-.08l1.66 1.66c-.71.33-1.5.52-2.31.52-2.76 0-5.3-2.1-5.3-5.1H5c0 3.41 2.72 6.23 6 6.72V21h2v-3.28c.91-.13 1.77-.45 2.54-.9L19.73 21 21 19.73 4.27 3z"/></svg>
        </div>
        <span id="micLabel">Mic</span>
    </button>

    <button class="ctrl-btn" id="camBtn" onclick="toggleCam()" title="Camera (E)">
        <div class="ctrl-icon">
            <svg id="camOnIcon" viewBox="0 0 24 24"><path d="M17 10.5V7c0-.55-.45-1-1-1H4c-.55 0-1 .45-1 1v10c0 .55.45 1 1 1h12c.55 0 1-.45 1-1v-3.5l4 4v-11l-4 4z"/></svg>
            <svg id="camOffIcon" viewBox="0 0 24 24" style="display:none"><path d="M21 6.5l-4-4-5 5-3-3-4.5 4.5 8.5 8.5L21 6.5zM3.27 2 2 3.27l4.5 4.5L2 12.5V17c0 .55.45 1 1 1h11.73l2 2L18 18.73 3.27 2zM16 12.27V17H5.27L16 6.27v6z"/></svg>
        </div>
        <span id="camLabel">Camera</span>
    </button>

    <div class="ctrl-sep"></div>

    <button class="ctrl-btn" id="screenBtn" onclick="toggleScreen()" title="Share Screen">
        <div class="ctrl-icon">
            <svg viewBox="0 0 24 24"><path d="M20 18c1.1 0 1.99-.9 1.99-2L22 6c0-1.1-.9-2-2-2H4c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2H0v2h24v-2h-4zm-9-3v-2H7v-2h4V9l3 3-3 3z"/></svg>
        </div>
        <span id="screenLabel">Share Screen</span>
    </button>

    <div class="ctrl-sep"></div>

    <button class="ctrl-btn end-call" onclick="handleEndClick()" title="End Call (Esc)">
        <div class="ctrl-icon">
            <svg viewBox="0 0 24 24"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
        </div>
        <span>End</span>
    </button>
</div>

<!-- PARTICIPANT DRAWER OVERLAY -->
<div id="drawerOverlay" onclick="closeDrawer()"></div>

<!-- PARTICIPANT DRAWER -->
<div id="participantDrawer">
    <div id="drawerHeader">
        <div id="drawerTitle">
            <svg viewBox="0 0 24 24"><path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/></svg>
            Participants
            <span id="drawerCountBadge">1</span>
        </div>
        <button id="drawerCloseBtn" onclick="closeDrawer()">
            <svg viewBox="0 0 24 24"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/></svg>
        </button>
    </div>
    <div id="participantList"></div>
</div>

<!-- HOST END CALL MODAL -->
<div id="endCallModalOverlay">
    <div id="endCallModal">
        <h3>Leave this call?</h3>
        <p>Choose whether to leave and let others continue, or end the call for everyone.</p>
        <div class="modal-btn-row">
            <button class="modal-btn leave" onclick="doLeaveCall()">
                <svg viewBox="0 0 24 24"><path d="M10.09 15.59L11.5 17l5-5-5-5-1.41 1.41L12.67 11H3v2h9.67l-2.58 2.59zM19 3H5c-1.11 0-2 .9-2 2v4h2V5h14v14H5v-4H3v4c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2z"/></svg>
                Leave Call
            </button>
            <button class="modal-btn end-all" onclick="doEndForAll()">
                <svg viewBox="0 0 24 24"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
                End for All
            </button>
            <button class="modal-btn cancel" onclick="closeEndModal()">Cancel</button>
        </div>
    </div>
</div>

<div id="toast"></div>
<audio id="remoteAudio" autoplay></audio>

<script>
// ── State ───────────────────────────────────────────────────────────────────
var room          = null;
var sdk           = null;
var micEnabled    = true;
var camEnabled    = true;
var screenTrack   = null;
var screenSid     = null;
var callStartTime = null;
var timerInterval = null;
var micAvailable  = true;
var camAvailable  = true;
var pinnedId      = 'local';
var remoteTracks  = {};
var remoteParticipants = {}; // identity → { name, micMuted }

var recordState = 'idle';
var currentEgressId = null;

var urlParams = new URLSearchParams(window.location.search);
var roomId    = urlParams.get('room');
var token     = urlParams.get('token');
var isHost    = urlParams.get('role') === 'host' || urlParams.get('host') === '1' || urlParams.get('host') === 'true';

// ── Recording ───────────────────────────────────────────────────────────────
async function toggleRecording() {
    if (recordState === 'idle') {
        recordState = 'recording';
        updateRecordUI();
        try {
            var res = await fetch('/api/startrecording', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ roomId: roomId })
            });
            if (!res.ok) throw new Error('Status ' + res.status);
            var data = await res.json();
            if (data.egressId) {
                currentEgressId = data.egressId;
                showToast("Recording started");
            } else {
                throw new Error("No egressId returned");
            }
        } catch(e) {
            recordState = 'idle';
            updateRecordUI();
            showToast("Recording failed: " + e.message);
        }
    } else if (recordState === 'recording') {
        if (!currentEgressId) return;
        recordState = 'stopping';
        updateRecordUI();
        try {
            var res = await fetch('/api/stoprecording', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ egressId: currentEgressId })
            });
            if (!res.ok) throw new Error('Status ' + res.status);
            currentEgressId = null;
            recordState = 'idle';
            updateRecordUI();
            showToast("Recording stopped");
        } catch(e) {
            recordState = 'recording';
            updateRecordUI();
            showToast("Could not stop recording: " + e.message);
        }
    }
}

function updateRecordUI() {
    var btn = document.getElementById('recordBtn');
    var txt = document.getElementById('recordText');
    if (!btn) return;
    if (recordState === 'idle') {
        btn.className = '';
        btn.disabled = false;
        txt.innerText = 'REC';
    } else if (recordState === 'recording') {
        btn.className = 'recording';
        btn.disabled = false;
        txt.innerText = 'Recording';
    } else if (recordState === 'stopping') {
        btn.className = '';
        btn.disabled = true;
        txt.innerText = 'Stopping…';
    }
}

function stopRecordingIfNeeded() {
    if (recordState === 'recording' && currentEgressId) {
        fetch('/api/stoprecording', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ egressId: currentEgressId })
        }).catch(function(){});
        recordState = 'stopping';
        updateRecordUI();
    }
}

// ── Timer ───────────────────────────────────────────────────────────────────
function startTimer() {
    callStartTime = Date.now();
    timerInterval = setInterval(function() {
        var s = Math.floor((Date.now() - callStartTime) / 1000);
        var m = Math.floor(s/60); s = s%60;
        var h = Math.floor(m/60); m = m%60;
        document.getElementById('callTimer').innerText =
            (h > 0 ? h+':' : '') + (h > 0 ? String(m).padStart(2,'0') : m) + ':' + String(s).padStart(2,'0');
    }, 1000);
}

// ── Toast ───────────────────────────────────────────────────────────────────
function showToast(msg, dur) {
    var t = document.getElementById('toast');
    t.innerText = msg; t.classList.add('show');
    clearTimeout(t._t);
    t._t = setTimeout(function(){ t.classList.remove('show'); }, dur || 2500);
}

// ── Status ──────────────────────────────────────────────────────────────────
function setStatus(state) {
    document.getElementById('statusPill').className = state;
    document.getElementById('statusText').innerText =
        state === 'connected' ? 'Connected' :
        state === 'error'     ? 'Error'     : 'Connecting…';
    document.getElementById('roomLabel').innerText = roomId ? '· ' + roomId : '';
}

// ── Preview ──────────────────────────────────────────────────────────────────
async function previewCamera() {
    try {
        var s = await navigator.mediaDevices.getUserMedia({ video:true, audio:false });
        document.getElementById('previewVideo').srcObject = s;
    } catch(e) {
        document.getElementById('previewVideo').style.display = 'none';
        document.getElementById('previewNoCamera').style.display = 'flex';
        document.getElementById('joinSubtitle').innerText = 'Camera unavailable — you can still join.';
    }
}
previewCamera();

// ── doJoin ──────────────────────────────────────────────────────────────────
function doJoin() {
    var pv = document.getElementById('previewVideo');
    if (pv.srcObject) { pv.srcObject.getTracks().forEach(function(t){ t.stop(); }); }
    document.getElementById('joinOverlay').style.display = 'none';
    start();
}

// ── Main connect ─────────────────────────────────────────────────────────────
async function start() {
    if (room !== null) {
        console.log('[CONNECT] WARNING: room already exists, state:', room.state);
        try { await room.disconnect(); } catch(e){}
        await new Promise(r => setTimeout(r, 500));
        room = null;
    }

    console.log('[CONNECT] start() called, roomId:', roomId, 'token length:', token ? token.length : 0);
    if (!roomId || !token) { setStatus('error'); return; }
    sdk = window.LiveKitClient || window.LivekitClient;
    console.log('[CONNECT] SDK found:', !!sdk, 'SDK version:', sdk.version || 'unknown');
    if (!sdk) { setStatus('error'); return; }
    setStatus('connecting');

    try {
        room = new sdk.Room();
        console.log('[CONNECT] room object created');

        room.on(sdk.RoomEvent.MediaDevicesError, function(error) {
            console.log('[CONNECT] MediaDevicesError', error.name, error.message);
        });
        room.on(sdk.RoomEvent.SignalConnected, function() {
            console.log('[CONNECT] SignalConnected fired');
        });
        room.on(sdk.RoomEvent.Connected, function() {
            console.log('[CONNECT] Connected event fired, room.state:', room.state);
        });

        room.on(sdk.RoomEvent.TrackSubscribed, function(track, pub, participant) {
            if (participant) {
                if (!remoteParticipants[participant.identity]) {
                    remoteParticipants[participant.identity] = { name: participant.identity, micMuted: false };
                    addParticipantTile(participant);
                }
            }
            if (track.kind === 'video') { 
                updateParticipantVideo(participant, track);
            }
            if (track.kind === 'audio') {
                var a = document.getElementById('remoteAudio');
                track.attach(a); a.play().catch(function(){});
            }
            updateParticipantCount();
            renderParticipantList();
        });

        room.on(sdk.RoomEvent.TrackUnsubscribed, function(track, pub, participant) {
            if (track.kind === 'video' && participant) { 
                clearParticipantVideo(participant);
            }
        });

        room.on(sdk.RoomEvent.ParticipantConnected, function(p) {
            remoteParticipants[p.identity] = { name: p.identity, micMuted: false };
            addParticipantTile(p);
            updateParticipantCount();
            renderParticipantList();
            showToast(p.identity + ' joined');
        });

        room.on(sdk.RoomEvent.ParticipantDisconnected, function(p) {
            delete remoteParticipants[p.identity];
            removeParticipantTile(p.identity);
            updateParticipantCount();
            renderParticipantList();
            showToast(p.identity + ' left the call');
        });

        room.on(sdk.RoomEvent.TrackMuted, function(pub, participant) {
            if (pub.kind === 'audio') {
                console.log('[MIC] TrackMuted event:', participant ? participant.identity : 'unknown', 'sid:', pub.trackSid, 'isMuted:', pub.isMuted);
                if (participant) {
                    var smuteEl = document.getElementById('smute_' + participant.identity);
                    console.log('[MIC] smute_ element exists for', participant.identity, ':', !!smuteEl);
                    if (smuteEl) smuteEl.classList.add('show');
                    if (pinnedId === participant.identity) {
                        var mainMutedBadge = document.getElementById('mainMutedBadge');
                        if (mainMutedBadge) mainMutedBadge.classList.add('show');
                    }
                    if (remoteParticipants[participant.identity]) {
                        remoteParticipants[participant.identity].micMuted = true;
                    }
                    renderParticipantList();
                }
            }
        });

        room.on(sdk.RoomEvent.TrackUnmuted, function(pub, participant) {
            if (pub.kind === 'audio') {
                console.log('[MIC] TrackUnmuted event:', participant ? participant.identity : 'unknown', 'sid:', pub.trackSid, 'isMuted:', pub.isMuted);
                if (participant) {
                    var smuteEl = document.getElementById('smute_' + participant.identity);
                    console.log('[MIC] smute_ element exists for', participant.identity, ':', !!smuteEl);
                    if (smuteEl) smuteEl.classList.remove('show');
                    if (pinnedId === participant.identity) {
                        var mainMutedBadge = document.getElementById('mainMutedBadge');
                        if (mainMutedBadge) mainMutedBadge.classList.remove('show');
                    }
                    if (remoteParticipants[participant.identity]) {
                        remoteParticipants[participant.identity].micMuted = false;
                    }
                    renderParticipantList();
                }
            }
        });

        // Data messages (guest listens for endForAll)
        room.on(sdk.RoomEvent.DataReceived, function(payload) {
            try {
                var msg = JSON.parse(new TextDecoder().decode(payload));
                if (msg && msg.action === 'endForAll') {
                    showToast('Host ended the call', 3000);
                    setTimeout(function() {
                        endCallScreen();
                    }, 2000);
                }
            } catch(e) {}
        });

        room.on(sdk.RoomEvent.Disconnected, function(reason) {
            console.log('[CONNECT] Disconnected reason:', reason, 'room.state:', room ? room.state : 'null');
            setStatus('error'); clearInterval(timerInterval);
            showToast('Disconnected. Reconnecting…', 4000);
            setTimeout(function(){ window.location.reload(); }, 3000);
        });

        var proto = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
        var connectUrl = proto + '//' + window.location.host;
        console.log('[CONNECT] Before room.connect, url:', connectUrl);
        await room.connect(connectUrl, token, { autoSubscribe: true });
        console.log('[CONNECT] After room.connect resolves, room.state:', room.state, 'room.sid:', room.sid, 'room.name:', room.name);
        setStatus('connected'); startTimer();

        // Populate existing remote participants
        var existingParticipants = room.remoteParticipants || room.participants;
        if (existingParticipants) {
            existingParticipants.forEach(function(p) {
                remoteParticipants[p.identity] = { name: p.identity, micMuted: false };
                addParticipantTile(p);
                // Check for existing tracks
                var tracks = p.videoTracks || p.tracks;
                if (tracks) {
                    tracks.forEach(function(pub) {
                        if (pub.track && pub.kind === 'video') updateParticipantVideo(p, pub.track);
                    });
                }
            });
        }
        updateParticipantCount();
        renderParticipantList();

        // Try media
        var tracks = [];
        console.log('[CONNECT] media capture starting');
        try {
            tracks = await sdk.createLocalTracks({ audio:true, video:true });
            console.log('[CONNECT] media capture success (audio+video)');
            micAvailable = true; camAvailable = true;
        } catch(e) {
            console.log('[CONNECT] media capture failure (audio+video):', e.name, e.message);
            try {
                tracks = await sdk.createLocalTracks({ audio:true, video:false });
                console.log('[CONNECT] media capture success (audio only)');
                micAvailable = true; camAvailable = false; showToast('Camera unavailable');
            } catch(e2) {
                console.log('[CONNECT] media capture failure (audio only):', e2.name, e2.message);
                try { 
                    tracks = await sdk.createLocalTracks({ audio:false, video:false }); 
                    console.log('[CONNECT] media capture success (none)');
                } catch(e3){
                    console.log('[CONNECT] media capture failure (none):', e3.name, e3.message);
                }
                micAvailable = false; camAvailable = false; showToast('Mic and camera unavailable');
            }
        }

        if (!micAvailable) {
            micEnabled = false;
            var mb = document.getElementById('micBtn');
            mb.disabled = true; mb.title = 'Microphone not available';
            setMicUI(false);
        }
        if (!camAvailable) {
            camEnabled = false;
            var cb = document.getElementById('camBtn');
            cb.disabled = true; cb.title = 'Camera not available';
            setCamUI(false);
        }

        for (var i = 0; i < tracks.length; i++) {
            var t = tracks[i];
            await room.localParticipant.publishTrack(t);
            console.log('[CONNECT] published track:', t.sid, t.kind, t.mediaStreamTrack ? t.mediaStreamTrack.readyState : 'unknown');
            if (t.kind === 'video') {
                t.attach(document.getElementById('mainVideo'));
                document.getElementById('mainVideo').style.display = 'block';
                document.getElementById('mainAvatar').style.display = 'none';
            }
        }

        buildLocalSidebarTile();

        console.log('[CONNECT] start() completed successfully');

    } catch(err) {
        console.log('[CONNECT] start() catch:', err.name, err.message, err.stack);
        setStatus('error');
        showToast('Error: ' + err.message, 5000);
        console.error('VC:', err);
    }
}

// ── Participant count & list ──────────────────────────────────────────────────
function updateParticipantCount() {
    var remoteCount = 0;
    if (room && room.remoteParticipants) { remoteCount = room.remoteParticipants.size; }
    else { remoteCount = Object.keys(remoteParticipants).length; }
    
    var count = 1 + remoteCount;
    var el = document.getElementById('participantCount');
    if (el) el.innerText = count;
    var badge = document.getElementById('drawerCountBadge');
    if (badge) badge.innerText = count;
}

function renderParticipantList() {
    var list = document.getElementById('participantList');
    list.innerHTML = '';

    // Self first
    var selfName = (room && room.localParticipant && room.localParticipant.identity)
        ? room.localParticipant.identity : 'You';
    var selfItem = makeParticipantItem(selfName, !micEnabled, true);
    list.appendChild(selfItem);

    // Remote participants
    Object.keys(remoteParticipants).forEach(function(id) {
        var p = remoteParticipants[id];
        var item = makeParticipantItem(p.name, p.micMuted, false);
        list.appendChild(item);
    });
}

function makeParticipantItem(name, isMuted, isSelf) {
    var item = document.createElement('div');
    item.className = 'p-item';

    var av = document.createElement('div');
    av.className = 'p-avatar';
    av.innerText = name.charAt(0).toUpperCase();
    item.appendChild(av);

    var nameWrap = document.createElement('div');
    nameWrap.style.cssText = 'flex:1; overflow:hidden;';
    var nameEl = document.createElement('div');
    nameEl.className = 'p-name';
    nameEl.innerText = name;
    if (isSelf) {
        var tag = document.createElement('span');
        tag.className = 'p-you-tag'; tag.innerText = 'You';
        nameEl.appendChild(tag);
    }
    nameWrap.appendChild(nameEl);
    item.appendChild(nameWrap);

    var micEl = document.createElement('div');
    micEl.className = 'p-mic-icon' + (isMuted ? ' muted' : '');
    if (isMuted) {
        micEl.innerHTML = '<svg viewBox="0 0 24 24"><path d="M19 11h-1.7c0 .74-.16 1.43-.43 2.05l1.23 1.23c.56-.98.9-2.09.9-3.28zm-4.02.17c0-.06.02-.11.02-.17V5c0-1.66-1.34-3-3-3S9 3.34 9 5v.18l5.98 5.99zM4.27 3 3 4.27l6.01 6.01V11c0 1.66 1.33 3 2.99 3 .22 0 .44-.03.65-.08l1.66 1.66c-.71.33-1.5.52-2.31.52-2.76 0-5.3-2.1-5.3-5.1H5c0 3.41 2.72 6.23 6 6.72V21h2v-3.28c.91-.13 1.77-.45 2.54-.9L19.73 21 21 19.73 4.27 3z"/></svg>';
    } else {
        micEl.innerHTML = '<svg viewBox="0 0 24 24"><path d="M12 14c1.66 0 3-1.34 3-3V5c0-1.66-1.34-3-3-3S9 3.34 9 5v6c0 1.66 1.34 3 3 3zm5.3-3c0 3-2.54 5.1-5.3 5.1S6.7 14 6.7 11H5c0 3.41 2.72 6.23 6 6.72V21h2v-3.28c3.28-.49 6-3.31 6-6.72h-1.7z"/></svg>';
    }
    item.appendChild(micEl);

    return item;
}

// ── Drawer ───────────────────────────────────────────────────────────────────
function toggleDrawer() {
    var drawer = document.getElementById('participantDrawer');
    var overlay = document.getElementById('drawerOverlay');
    if (drawer.classList.contains('open')) {
        closeDrawer();
    } else {
        renderParticipantList();
        drawer.classList.add('open');
        overlay.classList.add('open');
    }
}

function closeDrawer() {
    document.getElementById('participantDrawer').classList.remove('open');
    document.getElementById('drawerOverlay').classList.remove('open');
}

// ── Sidebar Management ──────────────────────────────────────────────────────
function addParticipantTile(p) {
    var id = p.identity;
    if (document.getElementById('s_' + id)) return;

    var tile = makeSidebarTile('s_' + id, id, false);
    tile.onclick = function(){ pinParticipant(id); };

    var muteEl = document.createElement('div');
    muteEl.className = 's-tile-muted'; muteEl.id = 'smute_' + id;
    muteEl.innerHTML = '<svg viewBox="0 0 24 24"><path d="M19 11h-1.7c0 .74-.16 1.43-.43 2.05l1.23 1.23c.56-.98.9-2.09.9-3.28zm-4.02.17c0-.06.02-.11.02-.17V5c0-1.66-1.34-3-3-3S9 3.34 9 5v.18l5.98 5.99zM4.27 3 3 4.27l6.01 6.01V11c0 1.66 1.33 3 2.99 3 .22 0 .44-.03.65-.08l1.66 1.66c-.71.33-1.5.52-2.31.52-2.76 0-5.3-2.1-5.3-5.1H5c0 3.41 2.72 6.23 6 6.72V21h2v-3.28c.91-.13 1.77-.45 2.54-.9L19.73 21 21 19.73 4.27 3z"/></svg>';
    tile.appendChild(muteEl);

    document.getElementById('sidebar').appendChild(tile);
    remoteTracks[id] = { name: id, tileEl: tile };

    // Auto-pin if it's the first remote
    if (pinnedId === 'local') { pinParticipant(id); }
}

function removeParticipantTile(id) {
    var data = remoteTracks[id];
    if (data) {
        if (data.tileEl) data.tileEl.remove();
        delete remoteTracks[id];
    }
    if (pinnedId === id) pinParticipant('local');
}

function updateParticipantVideo(p, track) {
    console.log('[PIN] incoming track - sid:', track.sid, 'identity:', p.identity, 'source:', track.source, 'kind:', track.kind);
    console.log('[PIN] track object keys:', Object.keys(track));
    var id = p.identity;
    var data = remoteTracks[id];
    if (!data) { addParticipantTile(p); data = remoteTracks[id]; }

    // Remove old video if any
    var oldV = data.tileEl.querySelector('video');
    if (oldV) oldV.remove();

    var v = document.createElement('video');
    v.autoplay = true; v.playsinline = true;
    v.style.cssText = 'width:100%;height:100%;object-fit:cover;display:block;';
    track.attach(v);
    data.tileEl.insertBefore(v, data.tileEl.firstChild);
    data.tileEl.classList.add('has-video');
    data.track = track;
    data.isScreen = (track.source === 'screen_share' || (sdk.Track && track.source === sdk.Track.Source.ScreenShare));

    if (data.isScreen) {
        if (!data.tileEl.querySelector('.s-screen-badge')) {
            var sb = document.createElement('div');
            sb.className = 's-screen-badge'; sb.innerText = '● Screen';
            data.tileEl.appendChild(sb);
        }
        pinParticipant(id);
    } else if (pinnedId === id) {
        // If this participant is currently pinned, update the main video too
        var mainVideo = document.getElementById('mainVideo');
        track.attach(mainVideo);
        mainVideo.style.display = 'block';
        document.getElementById('mainAvatar').style.display = 'none';
        mainVideo.play().catch(function(){});
    }
}

function clearParticipantVideo(p) {
    var id = p.identity;
    var data = remoteTracks[id];
    if (data) {
        var v = data.tileEl.querySelector('video');
        if (v) v.remove();
        data.tileEl.classList.remove('has-video');
        delete data.track;
    }
    if (pinnedId === id) {
        var mainVideo = document.getElementById('mainVideo');
        mainVideo.style.display = 'none';
        document.getElementById('mainAvatar').style.display = 'flex';
    }
}

// ── Sidebar Tiles Helpers ────────────────────────────────────────────────────
function buildLocalSidebarTile() {
    if (document.getElementById('s_local')) return;
    var tile = makeSidebarTile('s_local', 'You', false);
    tile.onclick = function(){ pinParticipant('local'); };

    var muteEl = document.createElement('div');
    muteEl.className = 's-tile-muted'; muteEl.id = 's_local_muted';
    muteEl.innerHTML = '<svg viewBox="0 0 24 24"><path d="M19 11h-1.7c0 .74-.16 1.43-.43 2.05l1.23 1.23c.56-.98.9-2.09.9-3.28zm-4.02.17c0-.06.02-.11.02-.17V5c0-1.66-1.34-3-3-3S9 3.34 9 5v.18l5.98 5.99zM4.27 3 3 4.27l6.01 6.01V11c0 1.66 1.33 3 2.99 3 .22 0 .44-.03.65-.08l1.66 1.66c-.71.33-1.5.52-2.31.52-2.76 0-5.3-2.1-5.3-5.1H5c0 3.41 2.72 6.23 6 6.72V21h2v-3.28c.91-.13 1.77-.45 2.54-.9L19.73 21 21 19.73 4.27 3z"/></svg>';
    tile.appendChild(muteEl);

    document.getElementById('sidebar').appendChild(tile);
    
    // Attach local video if available
    if (camEnabled) {
        var v = document.createElement('video');
        v.autoplay = true; v.muted = true; v.playsinline = true;
        v.style.cssText = 'width:100%;height:100%;object-fit:cover;display:block;';
        var mainV = document.getElementById('mainVideo');
        console.log('[PIN] buildLocalSidebarTile - mainVideo.srcObject exists:', !!mainV.srcObject);
        if (mainV.srcObject) { v.srcObject = mainV.srcObject; tile.classList.add('has-video'); }
        tile.insertBefore(v, tile.firstChild);
    }

    if (pinnedId === 'local') { tile.classList.add('pinned'); }
}

function makeSidebarTile(id, name, isScreen) {
    var tile = document.createElement('div');
    tile.className = 's-tile'; tile.id = id;
    var avEl = document.createElement('div');
    avEl.className = 's-tile-avatar'; avEl.innerText = name.charAt(0).toUpperCase();
    tile.appendChild(avEl);
    if (isScreen) {
        var sb = document.createElement('div');
        sb.className = 's-screen-badge'; sb.innerText = '● Screen';
        tile.appendChild(sb);
    }
    var lbl = document.createElement('div');
    lbl.className = 's-tile-label'; lbl.innerText = name + (isScreen ? ' · Screen' : '');
    tile.appendChild(lbl);
    var hint = document.createElement('div');
    hint.className = 's-tile-hint'; hint.innerText = 'Pin';
    tile.appendChild(hint);
    return tile;
}

// ── Pin ──────────────────────────────────────────────────────────────────────
function pinParticipant(id) {
    console.log('[PIN] pinParticipant called with id:', id, 'current pinnedId:', pinnedId);
    pinnedId = id;
    document.querySelectorAll('.s-tile').forEach(function(t){ t.classList.remove('pinned'); });

    var mainVideo   = document.getElementById('mainVideo');
    var mainAvatar  = document.getElementById('mainAvatar');
    var mainLblText = document.getElementById('mainLabelText');
    var mainMuted   = document.getElementById('mainMutedBadge');
    var screenBadge = document.getElementById('mainScreenBadge');

    mainAvatar.style.display  = 'none';
    mainVideo.style.display   = 'none';
    screenBadge.style.display = 'none';
    mainMuted.classList.remove('show');

    if (id === 'local') {
        console.log('[PIN] Branch: local');
        mainLblText.innerText = 'You';
        if (room && room.localParticipant) {
            var vTracks = [];
            if (room.localParticipant.videoTracks) {
                room.localParticipant.videoTracks.forEach(function(publication) {
                    if (publication && publication.track) { vTracks.push(publication.track); }
                });
            }
            if (vTracks.length > 0 && camEnabled) {
                vTracks[0].attach(mainVideo);
                console.log('[PIN] mainVideo.srcObject after attach (local):', mainVideo.srcObject);
                mainVideo.style.display = 'block';
                mainAvatar.style.display = 'none';
            } else {
                mainVideo.style.display = 'none';
                mainAvatar.style.display = 'flex';
            }
        } else {
            mainAvatar.style.display = 'flex';
        }
        if (!micEnabled) mainMuted.classList.add('show');

        var lt = document.getElementById('s_local');
        if (lt) lt.classList.add('pinned');

    } else {
        console.log('[PIN] Branch: remote');
        var data = remoteTracks[id];
        console.log('[PIN] remoteTracks['+id+']:', data);
        if (!data) { pinParticipant('local'); return; }

        console.log('[PIN] isScreenLocal:', !!data.isScreenLocal);

        mainLblText.innerText = data.name + (data.isScreen ? ' · Screen' : '');
        if (data.isScreen) screenBadge.style.display = 'block';

        console.log('[PIN] data.track exists:', !!data.track, 'type:', data.track ? typeof data.track : 'undefined');
        if (!data || !data.track || typeof data.track.attach !== 'function') {
            console.error('[PIN] track missing for sid:', id, 'falling back to local');
            pinParticipant('local');
            return;
        }
        if (data.track) {
            console.log('[PIN] data.track.attach is function:', typeof data.track.attach === 'function');
            try {
                data.track.attach(mainVideo);
            } catch (err) {
                console.log('[PIN] Error attaching data.track:', err);
            }
            console.log('[PIN] mainVideo.srcObject after attach (remote track):', mainVideo.srcObject ? 'MediaStream' : 'null');
            setTimeout(function() {
                console.log('[PIN] mainVideo.readyState:', mainVideo.readyState, 'mainVideo.videoWidth:', mainVideo.videoWidth);
            }, 500);

            mainVideo.style.display = 'block';
            mainVideo.play().catch(function(){});
        } else if (data.isScreenLocal && data.stream) {
            mainVideo.srcObject = data.stream;
            mainVideo.style.display = 'block';
            mainVideo.play().catch(function(){});
        } else {
            mainAvatar.style.display = 'flex';
        }

        var tile = document.getElementById('s_' + id);
        if (tile) tile.classList.add('pinned');
    }
}

// ── Mic ──────────────────────────────────────────────────────────────────────
function setMicUI(on) {
    console.log('[MIC] setMicUI called, on:', on, 'micAvailable:', micAvailable);
    if (room && room.localParticipant) {
        console.log('[MIC] current localParticipant.isMicrophoneEnabled:', room.localParticipant.isMicrophoneEnabled);
    }
    document.getElementById('micOnIcon').style.display  = on ? 'block' : 'none';
    document.getElementById('micOffIcon').style.display = on ? 'none'  : 'block';
    document.getElementById('micLabel').innerText = on ? 'Mute' : 'Unmute';
    document.getElementById('micBtn').classList.toggle('off', !on);

    var sm = document.getElementById('s_local_muted');
    console.log('[MIC] sidebar local muted icon exists:', !!sm);
    if (sm) sm.classList.toggle('show', !on);
    if (pinnedId === 'local') {
        var mainMutedBadge = document.getElementById('mainMutedBadge');
        console.log('[MIC] pinnedId is local. mainMutedBadge classList:', mainMutedBadge ? mainMutedBadge.classList.toString() : 'null');
        if (mainMutedBadge) mainMutedBadge.classList.toggle('show', !on);
    }
    // Update participant list mic status
    renderParticipantList();
}

async function toggleMic() {
    if (!room || !room.localParticipant || !micAvailable) return;
    console.log('[MIC] toggleMic called, micEnabled before toggle:', micEnabled);
    micEnabled = !micEnabled;
    console.log('[MIC] calling setMicrophoneEnabled with:', micEnabled);
    try {
        await room.localParticipant.setMicrophoneEnabled(micEnabled);
        console.log('[MIC] setMicrophoneEnabled resolved, actual isMicrophoneEnabled:', room.localParticipant.isMicrophoneEnabled);
        setMicUI(micEnabled);
        showToast(micEnabled ? 'Mic on' : 'Mic muted');
    } catch(e) { 
        console.log('[MIC] Error in toggleMic:', e);
        micEnabled = !micEnabled; console.error(e); 
    }
}

// ── Camera ───────────────────────────────────────────────────────────────────
function setCamUI(on) {
    document.getElementById('camOnIcon').style.display  = on ? 'block' : 'none';
    document.getElementById('camOffIcon').style.display = on ? 'none'  : 'block';
    document.getElementById('camLabel').innerText = on ? 'Stop Cam' : 'Start Cam';
    document.getElementById('camBtn').classList.toggle('off', !on);

    // Update local sidebar tile avatar/video visibility
    var localTile = document.getElementById('s_local');
    if (localTile) {
        var localVid = localTile.querySelector('video');
        if (localVid) {
            localVid.style.display = on ? 'block' : 'none';
        }
        localTile.classList.toggle('has-video', on && !!localVid);
    }

    if (pinnedId === 'local') {
        var mainVideo = document.getElementById('mainVideo');
        var mainAvatar = document.getElementById('mainAvatar');
        mainVideo.style.display  = on ? 'block' : 'none';
        mainAvatar.style.display = on ? 'none'  : 'flex';
        if (on && room && room.localParticipant) {
            var vTracks = [];
            if (room.localParticipant.videoTracks) {
                room.localParticipant.videoTracks.forEach(function(publication) {
                    if (publication && publication.track) { vTracks.push(publication.track); }
                });
            }
            if (vTracks.length > 0) {
                vTracks[0].attach(mainVideo); mainVideo.play().catch(function(){});
            }
        }
    }
}

async function toggleCam() {
    if (!room || !room.localParticipant || !camAvailable) return;
    camEnabled = !camEnabled;
    try {
        await room.localParticipant.setCameraEnabled(camEnabled);
        setCamUI(camEnabled);
        showToast(camEnabled ? 'Camera on' : 'Camera off');
    } catch(e) { camEnabled = !camEnabled; console.error(e); }
}

// ── Screen share ─────────────────────────────────────────────────────────────
function setScreenUI(on) {
    document.getElementById('screenLabel').innerText = on ? 'Stop Sharing' : 'Share Screen';
    document.getElementById('screenBtn').classList.toggle('screen-on', on);
}

async function toggleScreen() {
    if (!room || !room.localParticipant) return;

    if (screenTrack) {
        try { await room.localParticipant.unpublishTrack(screenTrack); screenTrack.stop(); } catch(e){}
        if (screenSid) {
            var el = document.getElementById('s_' + screenSid);
            if (el) el.remove();
            if (pinnedId === screenSid) pinParticipant('local');
            delete remoteTracks[screenSid];
            screenSid = null;
        }
        screenTrack = null;
        setScreenUI(false);
        showToast('Screen sharing stopped');
        return;
    }

    try {
        var stream = await navigator.mediaDevices.getDisplayMedia({ video:true, audio:false });
        var mediaTrack = stream.getVideoTracks()[0];

        mediaTrack.addEventListener('ended', function() {
            if (screenTrack) { toggleScreen(); }
        });

        var lsTrack = new sdk.LocalVideoTrack(mediaTrack);
        await room.localParticipant.publishTrack(lsTrack, {
            source: sdk.Track && sdk.Track.Source ? sdk.Track.Source.ScreenShare : 'screen_share'
        });

        screenTrack = lsTrack;
        var sid = 'screen_' + Date.now();
        screenSid = sid;

        var tile = makeSidebarTile('s_' + sid, 'Your Screen', true);
        tile.onclick = function(){ pinParticipant(sid); };

        var v = document.createElement('video');
        v.autoplay = true; v.muted = true; v.playsinline = true;
        v.style.cssText = 'width:100%;height:100%;object-fit:cover;display:block;';
        v.srcObject = stream;
        tile.insertBefore(v, tile.firstChild);
        tile.classList.add('has-video');

        document.getElementById('sidebar').appendChild(tile);

        remoteTracks[sid] = {
            track: lsTrack, name: 'Your Screen', isScreen: true,
            isScreenLocal: true, stream: stream,
            tileEl: tile, videoEl: v
        };

        pinParticipant(sid);
        setScreenUI(true);
        showToast('Screen sharing started');
    } catch(e) {
        if (e.name !== 'NotAllowedError') {
            showToast('Screen share failed: ' + e.message, 4000);
            console.error(e);
        }
    }
}

// ── End call handling ─────────────────────────────────────────────────────────
function handleEndClick() {
    if (isHost) {
        // Show modal with Leave / End for All options
        document.getElementById('endCallModalOverlay').classList.add('open');
    } else {
        // Guest: just leave
        endCall();
    }
}

function closeEndModal() {
    document.getElementById('endCallModalOverlay').classList.remove('open');
}

// Host: leave only (others stay)
async function doLeaveCall() {
    closeEndModal();
    stopRecordingIfNeeded();
    if (screenTrack) {
        try { screenTrack.stop(); await room.localParticipant.unpublishTrack(screenTrack); } catch(e){}
    }
    if (room) { try { await room.disconnect(); } catch(e){} room = null; }
    clearInterval(timerInterval);
    endCallScreen();
}

// Host: end for all
async function doEndForAll() {
    closeEndModal();
    stopRecordingIfNeeded();
    if (room && room.localParticipant) {
        try {
            var msg = JSON.stringify({ action: 'endForAll' });
            await room.localParticipant.publishData(new TextEncoder().encode(msg), { reliable: true });
        } catch(e) { console.error('Failed to send endForAll:', e); }
    }
    // Small delay so guests receive the message before host disconnects
    setTimeout(async function() {
        if (screenTrack) {
            try { screenTrack.stop(); await room.localParticipant.unpublishTrack(screenTrack); } catch(e){}
        }
        if (room) { try { await room.disconnect(); } catch(e){} room = null; }
        clearInterval(timerInterval);
        endCallScreen();
    }, 400);
}

// ── End call (guest / common) ─────────────────────────────────────────────────
async function endCall() {
    stopRecordingIfNeeded();
    if (screenTrack) {
        try { screenTrack.stop(); await room.localParticipant.unpublishTrack(screenTrack); } catch(e){}
    }
    if (room) { try { await room.disconnect(); } catch(e){} room = null; }
    clearInterval(timerInterval);
    window.close();
    setTimeout(endCallScreen, 300);
}

function endCallScreen() {
    window.close();
    setTimeout(function() {
        document.body.innerHTML = '<div style="display:flex;align-items:center;justify-content:center;height:100vh;font-family:DM Sans,sans-serif;color:#6b7280;font-size:14px;background:#0a0b0d;letter-spacing:.02em;">Call ended — you can close this tab.</div>';
    }, 300);
}

// ── Keyboard ──────────────────────────────────────────────────────────────────
document.addEventListener('keydown', function(e) {
    if (e.target.tagName === 'INPUT') return;
    if (e.key === 'd') toggleMic();
    if (e.key === 'e') toggleCam();
    if (e.key === 'Escape') {
        // If modal or drawer open, close them first
        if (document.getElementById('endCallModalOverlay').classList.contains('open')) {
            closeEndModal(); return;
        }
        if (document.getElementById('participantDrawer').classList.contains('open')) {
            closeDrawer(); return;
        }
        handleEndClick();
    }
});
</script>

