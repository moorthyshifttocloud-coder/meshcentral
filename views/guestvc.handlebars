{{!-- <!DOCTYPE html>
<html>
<head>
    <title>Video Call - MeshCentral</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <script src="/scripts/livekit-client.umd.min.js"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --bg:          #0a0b0d;
            --surface:     #111316;
            --surface2:    #1a1d22;
            --surface3:    #22262d;
            --border:      rgba(255,255,255,0.07);
            --border2:     rgba(255,255,255,0.12);
            --text:        #f0f2f5;
            --text-dim:    #6b7280;
            --text-mid:    #9ca3af;
            --accent:      #3b82f6;
            --accent-glow: rgba(59,130,246,0.22);
            --green:       #22c55e;
            --red:         #ef4444;
            --red-dim:     rgba(239,68,68,0.14);
            --yellow:      #f59e0b;
            --radius:      12px;
            --radius-sm:   8px;
        }

        body {
            background: var(--bg);
            color: var(--text);
            font-family: 'DM Sans', sans-serif;
            height: 100vh;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            user-select: none;
        }

        /* ── TOP BAR ────────────────────────────────────────── */
        #topBar {
            height: 52px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 18px;
            background: var(--bg);
            border-bottom: 1px solid var(--border);
            flex-shrink: 0;
            z-index: 10;
        }

        #callInfo { display: flex; align-items: center; gap: 10px; }

        #statusPill {
            display: flex; align-items: center; gap: 6px;
            background: var(--surface2);
            border: 1px solid var(--border2);
            border-radius: 20px;
            padding: 4px 10px 4px 8px;
            font-size: 12px; font-weight: 500;
            color: var(--text-mid);
            transition: border-color 0.3s, color 0.3s;
        }
        #statusPill.connected { border-color: rgba(34,197,94,0.35); color: var(--green); }
        #statusPill.error     { border-color: rgba(239,68,68,0.35); color: var(--red); }

        #statusDot {
            width: 7px; height: 7px; border-radius: 50%;
            background: var(--yellow); flex-shrink: 0;
            transition: background 0.3s;
        }
        #statusPill.connected #statusDot { background: var(--green); box-shadow: 0 0 6px var(--green); }
        #statusPill.error     #statusDot { background: var(--red); }
        #statusPill.connecting #statusDot { animation: blink 1.4s ease-in-out infinite; }
        @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.2} }

        #roomLabel { font-size: 12px; font-weight: 500; color: var(--text-dim); }

        #callTimer {
            font-family: 'DM Mono', monospace;
            font-size: 13px; color: var(--text-dim);
            background: var(--surface2);
            padding: 4px 10px; border-radius: 6px;
            border: 1px solid var(--border);
            letter-spacing: 0.04em;
        }

        /* ── BODY ────────────────────────────────────────────── */
        #callBody {
            flex: 1; display: flex; overflow: hidden;
            background: #000; gap: 3px; padding: 3px;
        }

        /* ── MAIN VIEW ───────────────────────────────────────── */
        #mainView {
            flex: 1; position: relative;
            border-radius: var(--radius); overflow: hidden;
            background: var(--surface);
            display: flex; align-items: center; justify-content: center;
        }
        #mainVideo { width:100%; height:100%; object-fit:cover; display:block; }

        #mainAvatar {
            width: 88px; height: 88px; border-radius: 50%;
            background: var(--surface3);
            border: 2px solid var(--border2);
            display: none; align-items: center; justify-content: center;
            font-size: 32px; font-weight: 600; color: var(--text-mid);
            position: absolute;
        }

        #mainLabel {
            position: absolute; bottom: 14px; left: 14px;
            font-size: 13px; font-weight: 500; color: #fff;
            background: rgba(0,0,0,0.55);
            backdrop-filter: blur(10px);
            padding: 5px 12px; border-radius: 20px;
            border: 1px solid rgba(255,255,255,0.08);
            display: flex; align-items: center; gap: 6px;
            pointer-events: none;
        }

        #mainMutedBadge { display:none; align-items:center; justify-content:center; }
        #mainMutedBadge.show { display:flex; }
        #mainMutedBadge svg { width:14px; height:14px; fill:var(--red); }

        #mainScreenBadge {
            position: absolute; top: 13px; left: 13px;
            font-size: 10px; font-weight: 700; letter-spacing: 0.07em;
            text-transform: uppercase; color: var(--accent);
            background: var(--accent-glow);
            border: 1px solid rgba(59,130,246,0.4);
            padding: 3px 10px; border-radius: 20px;
            display: none; pointer-events: none;
        }

        /* ── SIDEBAR ─────────────────────────────────────────── */
        #sidebar {
            width: 214px; flex-shrink: 0;
            display: flex; flex-direction: column; gap: 3px;
            overflow-y: auto;
            scrollbar-width: thin;
            scrollbar-color: var(--surface3) transparent;
        }
        #sidebar::-webkit-scrollbar { width: 3px; }
        #sidebar::-webkit-scrollbar-thumb { background: var(--surface3); border-radius: 3px; }

        .s-tile {
            flex-shrink: 0; height: 144px;
            border-radius: var(--radius-sm);
            background: var(--surface);
            position: relative; overflow: hidden;
            cursor: pointer;
            border: 2px solid transparent;
            transition: border-color 0.18s, transform 0.15s;
            display: flex; align-items: center; justify-content: center;
        }
        .s-tile:hover { border-color: var(--border2); transform: scale(1.015); }
        .s-tile.pinned { border-color: var(--accent); }
        .s-tile video { width:100%; height:100%; object-fit:cover; display:block; }

        .s-tile-avatar {
            width: 44px; height: 44px; border-radius: 50%;
            background: var(--surface3);
            display: flex; align-items: center; justify-content: center;
            font-size: 17px; font-weight: 600; color: var(--text-mid);
            position: absolute;
        }

        .s-tile-label {
            position: absolute; bottom: 6px; left: 7px;
            font-size: 11px; font-weight: 500; color: #fff;
            background: rgba(0,0,0,0.6);
            backdrop-filter: blur(6px);
            padding: 2px 7px; border-radius: 9px;
            max-width: 130px; overflow: hidden;
            text-overflow: ellipsis; white-space: nowrap;
            pointer-events: none;
        }

        .s-tile-muted {
            position: absolute; bottom: 6px; right: 6px;
            width: 20px; height: 20px; border-radius: 50%;
            background: rgba(0,0,0,0.6);
            display: none; align-items: center; justify-content: center;
        }
        .s-tile-muted.show { display:flex; }
        .s-tile-muted svg { width:11px; height:11px; fill:var(--red); }

        .s-tile-hint {
            position: absolute; top: 50%; left: 50%;
            transform: translate(-50%,-50%);
            background: rgba(0,0,0,0.72); color:#fff;
            font-size: 11px; font-weight: 500;
            padding: 3px 9px; border-radius: 9px;
            opacity: 0; transition: opacity 0.18s; pointer-events: none;
        }
        .s-tile:hover .s-tile-hint { opacity: 1; }

        /* Screen badge inside sidebar tile */
        .s-screen-badge {
            position: absolute; top: 6px; left: 7px;
            font-size: 9px; font-weight: 700; letter-spacing: .06em;
            text-transform: uppercase; color: var(--accent);
            background: var(--accent-glow);
            border: 1px solid rgba(59,130,246,0.35);
            padding: 2px 6px; border-radius: 8px;
            pointer-events: none;
        }

        /* ── CONTROLS ────────────────────────────────────────── */
        #controls {
            height: 76px;
            background: var(--bg);
            border-top: 1px solid var(--border);
            display: flex; align-items: center; justify-content: center;
            gap: 6px; flex-shrink: 0; padding: 0 10px;
        }

        .ctrl-btn {
            display: flex; flex-direction: column;
            align-items: center; gap: 4px;
            background: none; border: none; cursor: pointer;
            font-family: 'DM Sans', sans-serif;
            font-size: 10px; font-weight: 500; color: var(--text-dim);
            padding: 4px 8px; border-radius: var(--radius-sm);
            transition: color 0.15s;
            letter-spacing: 0.02em;
        }
        .ctrl-btn:hover { color: var(--text); }
        .ctrl-btn:disabled { opacity: 0.28; cursor: not-allowed; }

        .ctrl-icon {
            width: 44px; height: 44px; border-radius: 50%;
            background: var(--surface2);
            border: 1px solid var(--border);
            display: flex; align-items: center; justify-content: center;
            transition: background 0.15s, border-color 0.15s, transform 0.1s;
        }
        .ctrl-btn:hover:not(:disabled) .ctrl-icon {
            background: var(--surface3); border-color: var(--border2);
        }
        .ctrl-btn:active:not(:disabled) .ctrl-icon { transform: scale(0.92); }
        .ctrl-icon svg { width: 20px; height: 20px; fill: var(--text-mid); transition: fill 0.15s; }

        .ctrl-btn.off .ctrl-icon { background: var(--red-dim); border-color: rgba(239,68,68,0.28); }
        .ctrl-btn.off .ctrl-icon svg { fill: var(--red); }
        .ctrl-btn.off { color: var(--red); }

        .ctrl-btn.screen-on .ctrl-icon { background: var(--accent-glow); border-color: rgba(59,130,246,0.38); }
        .ctrl-btn.screen-on .ctrl-icon svg { fill: var(--accent); }
        .ctrl-btn.screen-on { color: var(--accent); }

        .ctrl-sep { width:1px; height:26px; background:var(--border); margin:0 2px; flex-shrink:0; }

        .ctrl-btn.end-call .ctrl-icon {
            width: 50px; height: 50px;
            background: var(--red); border-color: transparent;
            animation: ring 2.5s ease-in-out infinite;
        }
        @keyframes ring {
            0%,100%{ box-shadow: 0 0 0 0 rgba(239,68,68,0.4); }
            50%     { box-shadow: 0 0 0 7px rgba(239,68,68,0); }
        }
        .ctrl-btn.end-call .ctrl-icon svg { fill:#fff; width:21px; height:21px; }
        .ctrl-btn.end-call { color: var(--red); }
        .ctrl-btn.end-call:hover .ctrl-icon { background:#dc2626; animation:none; }

        /* ── JOIN OVERLAY ────────────────────────────────────── */
        #joinOverlay {
            position: fixed; inset: 0;
            background: var(--bg); z-index: 200;
            display: flex; align-items: center; justify-content: center;
        }

        #joinCard {
            background: var(--surface);
            border: 1px solid var(--border2);
            border-radius: 20px; padding: 28px;
            display: flex; flex-direction: column;
            align-items: center; gap: 18px;
            width: 380px;
            box-shadow: 0 28px 60px rgba(0,0,0,0.7);
        }

        #previewWrap {
            width: 100%; height: 196px; border-radius: var(--radius);
            overflow: hidden; background: var(--surface2);
            position: relative;
            display: flex; align-items: center; justify-content: center;
        }
        #previewVideo { width:100%; height:100%; object-fit:cover; transform:scaleX(-1); }
        #previewNoCamera {
            display:none; flex-direction:column;
            align-items:center; gap:8px;
            color: var(--text-dim); font-size:13px;
        }
        #previewNoCamera svg { width:30px; height:30px; fill:var(--text-dim); opacity:.35; }

        #joinCard h2 { font-size: 21px; font-weight: 600; }
        #joinCard p  { font-size: 13px; color: var(--text-dim); text-align:center; line-height:1.5; }

        #joinBtn {
            width: 100%; background: var(--accent); color: #fff;
            border: none; padding: 12px;
            border-radius: var(--radius);
            font-size: 15px; font-family:'DM Sans',sans-serif;
            font-weight: 600; cursor: pointer;
            transition: background 0.2s, transform 0.1s;
            box-shadow: 0 4px 18px var(--accent-glow);
        }
        #joinBtn:hover { background: #2563eb; }
        #joinBtn:active { transform: scale(0.98); }

        /* ── TOAST ───────────────────────────────────────────── */
        #toast {
            position: fixed; bottom: 88px; left: 50%;
            transform: translateX(-50%) translateY(8px);
            background: var(--surface3); color: var(--text);
            border: 1px solid var(--border2);
            padding: 8px 16px; border-radius: 9px;
            font-size: 13px; font-weight: 500;
            opacity: 0; pointer-events: none;
            transition: opacity 0.2s, transform 0.2s;
            z-index: 300; white-space: nowrap;
            box-shadow: 0 8px 24px rgba(0,0,0,0.5);
        }
        #toast.show { opacity:1; transform: translateX(-50%) translateY(0); }
    </style>
</head>
<body>

<!-- TOP BAR -->
<div id="topBar">
    <div id="callInfo">
        <div id="statusPill" class="connecting">
            <div id="statusDot"></div>
            <span id="statusText">Connecting…</span>
        </div>
        <span id="roomLabel"></span>
    </div>
    <span id="callTimer">0:00</span>
</div>

<!-- CALL BODY -->
<div id="callBody">
    <div id="mainView">
        <video id="mainVideo" autoplay muted playsinline style="display:none"></video>
        <div id="mainAvatar">Y</div>
        <div id="mainScreenBadge">● Screen Share</div>
        <div id="mainLabel">
            <span id="mainLabelText">You</span>
            <div id="mainMutedBadge">
                <svg viewBox="0 0 24 24"><path d="M19 11h-1.7c0 .74-.16 1.43-.43 2.05l1.23 1.23c.56-.98.9-2.09.9-3.28zm-4.02.17c0-.06.02-.11.02-.17V5c0-1.66-1.34-3-3-3S9 3.34 9 5v.18l5.98 5.99zM4.27 3 3 4.27l6.01 6.01V11c0 1.66 1.33 3 2.99 3 .22 0 .44-.03.65-.08l1.66 1.66c-.71.33-1.5.52-2.31.52-2.76 0-5.3-2.1-5.3-5.1H5c0 3.41 2.72 6.23 6 6.72V21h2v-3.28c.91-.13 1.77-.45 2.54-.9L19.73 21 21 19.73 4.27 3z"/></svg>
            </div>
        </div>
    </div>
    <div id="sidebar"></div>
</div>

<!-- CONTROLS -->
<div id="controls">
    <button class="ctrl-btn" id="micBtn" onclick="toggleMic()" title="Microphone (D)">
        <div class="ctrl-icon">
            <svg id="micOnIcon" viewBox="0 0 24 24"><path d="M12 14c1.66 0 3-1.34 3-3V5c0-1.66-1.34-3-3-3S9 3.34 9 5v6c0 1.66 1.34 3 3 3zm5.3-3c0 3-2.54 5.1-5.3 5.1S6.7 14 6.7 11H5c0 3.41 2.72 6.23 6 6.72V21h2v-3.28c3.28-.49 6-3.31 6-6.72h-1.7z"/></svg>
            <svg id="micOffIcon" viewBox="0 0 24 24" style="display:none"><path d="M19 11h-1.7c0 .74-.16 1.43-.43 2.05l1.23 1.23c.56-.98.9-2.09.9-3.28zm-4.02.17c0-.06.02-.11.02-.17V5c0-1.66-1.34-3-3-3S9 3.34 9 5v.18l5.98 5.99zM4.27 3 3 4.27l6.01 6.01V11c0 1.66 1.33 3 2.99 3 .22 0 .44-.03.65-.08l1.66 1.66c-.71.33-1.5.52-2.31.52-2.76 0-5.3-2.1-5.3-5.1H5c0 3.41 2.72 6.23 6 6.72V21h2v-3.28c.91-.13 1.77-.45 2.54-.9L19.73 21 21 19.73 4.27 3z"/></svg>
        </div>
        <span id="micLabel">Mic</span>
    </button>

    <button class="ctrl-btn" id="camBtn" onclick="toggleCam()" title="Camera (E)">
        <div class="ctrl-icon">
            <svg id="camOnIcon" viewBox="0 0 24 24"><path d="M17 10.5V7c0-.55-.45-1-1-1H4c-.55 0-1 .45-1 1v10c0 .55.45 1 1 1h12c.55 0 1-.45 1-1v-3.5l4 4v-11l-4 4z"/></svg>
            <svg id="camOffIcon" viewBox="0 0 24 24" style="display:none"><path d="M21 6.5l-4-4-5 5-3-3-4.5 4.5 8.5 8.5L21 6.5zM3.27 2 2 3.27l4.5 4.5L2 12.5V17c0 .55.45 1 1 1h11.73l2 2L18 18.73 3.27 2zM16 12.27V17H5.27L16 6.27v6z"/></svg>
        </div>
        <span id="camLabel">Camera</span>
    </button>

    <div class="ctrl-sep"></div>

    <button class="ctrl-btn" id="screenBtn" onclick="toggleScreen()" title="Share Screen">
        <div class="ctrl-icon">
            <svg viewBox="0 0 24 24"><path d="M20 18c1.1 0 1.99-.9 1.99-2L22 6c0-1.1-.9-2-2-2H4c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2H0v2h24v-2h-4zm-9-3v-2H7v-2h4V9l3 3-3 3z"/></svg>
        </div>
        <span id="screenLabel">Share Screen</span>
    </button>

    <div class="ctrl-sep"></div>

    <button class="ctrl-btn end-call" onclick="endCall()" title="End Call (Esc)">
        <div class="ctrl-icon">
            <svg viewBox="0 0 24 24"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
        </div>
        <span>End</span>
    </button>
</div>

<!-- JOIN OVERLAY -->
<div id="joinOverlay">
    <div id="joinCard">
        <div id="previewWrap">
            <video id="previewVideo" autoplay muted playsinline></video>
            <div id="previewNoCamera">
                <svg viewBox="0 0 24 24"><path d="M21 6.5l-4-4-5 5-3-3-4.5 4.5 8.5 8.5L21 6.5zM3.27 2 2 3.27l4.5 4.5L2 12.5V17c0 .55.45 1 1 1h11.73l2 2L18 18.73 3.27 2zM16 12.27V17H5.27L16 6.27v6z"/></svg>
                <span>Camera not available</span>
            </div>
        </div>
        <div style="text-align:center; display:flex; flex-direction:column; gap:6px;">
            <h2>Ready to join?</h2>
            <p id="joinSubtitle">Your camera and mic will be enabled.</p>
        </div>
        <button id="joinBtn" onclick="doJoin()">Join Now</button>
    </div>
</div>

<div id="toast"></div>
<audio id="remoteAudio" autoplay></audio>

<script>
// ── State ───────────────────────────────────────────────────────────────────
var room          = null;
var sdk           = null;
var micEnabled    = true;
var camEnabled    = true;
var screenTrack   = null;
var screenSid     = null;
var callStartTime = null;
var timerInterval = null;
var micAvailable  = true;
var camAvailable  = true;
var pinnedId      = 'local';  // 'local' or a track sid
var remoteTracks  = {};       // sid → { track, name, isScreen, tileEl, videoEl, isScreenLocal }

var urlParams = new URLSearchParams(window.location.search);
var roomId    = urlParams.get('room');
var token     = urlParams.get('token');

// ── Timer ───────────────────────────────────────────────────────────────────
function startTimer() {
    callStartTime = Date.now();
    timerInterval = setInterval(function() {
        var s = Math.floor((Date.now() - callStartTime) / 1000);
        var m = Math.floor(s/60); s = s%60;
        var h = Math.floor(m/60); m = m%60;
        document.getElementById('callTimer').innerText =
            (h > 0 ? h+':' : '') + (h > 0 ? String(m).padStart(2,'0') : m) + ':' + String(s).padStart(2,'0');
    }, 1000);
}

// ── Toast ───────────────────────────────────────────────────────────────────
function showToast(msg, dur) {
    var t = document.getElementById('toast');
    t.innerText = msg; t.classList.add('show');
    clearTimeout(t._t);
    t._t = setTimeout(function(){ t.classList.remove('show'); }, dur || 2500);
}

// ── Status ──────────────────────────────────────────────────────────────────
function setStatus(state) {
    document.getElementById('statusPill').className = state;
    document.getElementById('statusText').innerText =
        state === 'connected' ? 'Connected' :
        state === 'error'     ? 'Error'     : 'Connecting…';
    document.getElementById('roomLabel').innerText = roomId ? '· ' + roomId : '';
}

// ── Preview ──────────────────────────────────────────────────────────────────
async function previewCamera() {
    try {
        var s = await navigator.mediaDevices.getUserMedia({ video:true, audio:false });
        document.getElementById('previewVideo').srcObject = s;
    } catch(e) {
        document.getElementById('previewVideo').style.display = 'none';
        document.getElementById('previewNoCamera').style.display = 'flex';
        document.getElementById('joinSubtitle').innerText = 'Camera unavailable — you can still join.';
    }
}
previewCamera();

// ── doJoin ──────────────────────────────────────────────────────────────────
function doJoin() {
    var pv = document.getElementById('previewVideo');
    if (pv.srcObject) { pv.srcObject.getTracks().forEach(function(t){ t.stop(); }); }
    document.getElementById('joinOverlay').style.display = 'none';
    start();
}

// ── Main connect ─────────────────────────────────────────────────────────────
async function start() {
    if (!roomId || !token) { setStatus('error'); return; }
    sdk = window.LiveKitClient || window.LivekitClient;
    if (!sdk) { setStatus('error'); return; }
    setStatus('connecting');

    try {
        room = new sdk.Room();

        room.on(sdk.RoomEvent.TrackSubscribed, function(track, pub, participant) {
            if (track.kind === 'video') { addRemoteTile(track, participant); }
            if (track.kind === 'audio') {
                var a = document.getElementById('remoteAudio');
                track.attach(a); a.play().catch(function(){});
            }
        });

        room.on(sdk.RoomEvent.TrackUnsubscribed, function(track) {
            if (track.kind === 'video') { removeRemoteTile(track.sid); }
        });

        room.on(sdk.RoomEvent.ParticipantDisconnected, function(p) {
            showToast(p.identity + ' left the call');
        });

        room.on(sdk.RoomEvent.Disconnected, function() {
            setStatus('error'); clearInterval(timerInterval);
            showToast('Disconnected. Reconnecting…', 4000);
            setTimeout(function(){ window.location.reload(); }, 3000);
        });

        var proto = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
        await room.connect(proto + '//' + window.location.host, token, { autoSubscribe: true });
        setStatus('connected'); startTimer();

        // Try media
        var tracks = [];
        try {
            tracks = await sdk.createLocalTracks({ audio:true, video:true });
            micAvailable = true; camAvailable = true;
        } catch(e) {
            try {
                tracks = await sdk.createLocalTracks({ audio:true, video:false });
                micAvailable = true; camAvailable = false; showToast('Camera unavailable');
            } catch(e2) {
                try { tracks = await sdk.createLocalTracks({ audio:false, video:false }); } catch(e3){}
                micAvailable = false; camAvailable = false; showToast('Mic and camera unavailable');
            }
        }

        if (!micAvailable) {
            micEnabled = false;
            var mb = document.getElementById('micBtn');
            mb.disabled = true; mb.title = 'Microphone not available';
            setMicUI(false);
        }
        if (!camAvailable) {
            camEnabled = false;
            var cb = document.getElementById('camBtn');
            cb.disabled = true; cb.title = 'Camera not available';
            setCamUI(false);
        }

        for (var i = 0; i < tracks.length; i++) {
            var t = tracks[i];
            await room.localParticipant.publishTrack(t);
            if (t.kind === 'video') {
                t.attach(document.getElementById('mainVideo'));
                document.getElementById('mainVideo').style.display = 'block';
                document.getElementById('mainAvatar').style.display = 'none';
            }
        }

        buildLocalSidebarTile();

    } catch(err) {
        setStatus('error');
        showToast('Error: ' + err.message, 5000);
        console.error('VC:', err);
    }
}

// ── Local sidebar tile ───────────────────────────────────────────────────────
function buildLocalSidebarTile() {
    if (document.getElementById('s_local')) return;
    var tile = makeSidebarTile('s_local', 'You', false);
    tile.onclick = function(){ pinParticipant('local'); };

    var v = document.createElement('video');
    v.autoplay = true; v.muted = true; v.playsinline = true;
    v.style.cssText = 'width:100%;height:100%;object-fit:cover;display:block;';
    var mainV = document.getElementById('mainVideo');
    if (mainV.srcObject) { v.srcObject = mainV.srcObject; }
    tile.insertBefore(v, tile.firstChild);

    var muteEl = document.createElement('div');
    muteEl.className = 's-tile-muted'; muteEl.id = 's_local_muted';
    muteEl.innerHTML = '<svg viewBox="0 0 24 24"><path d="M19 11h-1.7c0 .74-.16 1.43-.43 2.05l1.23 1.23c.56-.98.9-2.09.9-3.28zm-4.02.17c0-.06.02-.11.02-.17V5c0-1.66-1.34-3-3-3S9 3.34 9 5v.18l5.98 5.99zM4.27 3 3 4.27l6.01 6.01V11c0 1.66 1.33 3 2.99 3 .22 0 .44-.03.65-.08l1.66 1.66c-.71.33-1.5.52-2.31.52-2.76 0-5.3-2.1-5.3-5.1H5c0 3.41 2.72 6.23 6 6.72V21h2v-3.28c.91-.13 1.77-.45 2.54-.9L19.73 21 21 19.73 4.27 3z"/></svg>';
    tile.appendChild(muteEl);

    document.getElementById('sidebar').appendChild(tile);
    if (pinnedId === 'local') { tile.classList.add('pinned'); }
}

// ── Helper: build base sidebar tile ─────────────────────────────────────────
function makeSidebarTile(id, name, isScreen) {
    var tile = document.createElement('div');
    tile.className = 's-tile'; tile.id = id;

    var avEl = document.createElement('div');
    avEl.className = 's-tile-avatar';
    avEl.innerText = name.charAt(0).toUpperCase();
    tile.appendChild(avEl);

    if (isScreen) {
        var sb = document.createElement('div');
        sb.className = 's-screen-badge'; sb.innerText = '● Screen';
        tile.appendChild(sb);
    }

    var lbl = document.createElement('div');
    lbl.className = 's-tile-label';
    lbl.innerText = name + (isScreen ? ' · Screen' : '');
    tile.appendChild(lbl);

    var hint = document.createElement('div');
    hint.className = 's-tile-hint'; hint.innerText = 'Pin';
    tile.appendChild(hint);

    return tile;
}

// ── Add remote tile ──────────────────────────────────────────────────────────
function addRemoteTile(track, participant) {
    var sid = track.sid;
    if (remoteTracks[sid]) return;

    var isScreen = track.source === 'screen_share' ||
        (sdk.Track && sdk.Track.Source && track.source === sdk.Track.Source.ScreenShare);
    var name = participant ? participant.identity : 'Remote';

    var tile = makeSidebarTile('s_' + sid, name, isScreen);
    tile.onclick = function(){ pinParticipant(sid); };

    var v = document.createElement('video');
    v.autoplay = true; v.playsinline = true;
    v.style.cssText = 'width:100%;height:100%;object-fit:cover;display:block;';
    track.attach(v);
    tile.insertBefore(v, tile.firstChild);

    var muteEl = document.createElement('div');
    muteEl.className = 's-tile-muted'; muteEl.id = 'smute_' + sid;
    muteEl.innerHTML = '<svg viewBox="0 0 24 24"><path d="M19 11h-1.7c0 .74-.16 1.43-.43 2.05l1.23 1.23c.56-.98.9-2.09.9-3.28zm-4.02.17c0-.06.02-.11.02-.17V5c0-1.66-1.34-3-3-3S9 3.34 9 5v.18l5.98 5.99zM4.27 3 3 4.27l6.01 6.01V11c0 1.66 1.33 3 2.99 3 .22 0 .44-.03.65-.08l1.66 1.66c-.71.33-1.5.52-2.31.52-2.76 0-5.3-2.1-5.3-5.1H5c0 3.41 2.72 6.23 6 6.72V21h2v-3.28c.91-.13 1.77-.45 2.54-.9L19.73 21 21 19.73 4.27 3z"/></svg>';
    tile.appendChild(muteEl);

    document.getElementById('sidebar').appendChild(tile);
    remoteTracks[sid] = { track:track, name:name, isScreen:isScreen, tileEl:tile, videoEl:v };

    // Auto-pin: screen share takes priority, else pin first remote
    if (isScreen || pinnedId === 'local') { pinParticipant(sid); }
}

// ── Remove remote tile ───────────────────────────────────────────────────────
function removeRemoteTile(sid) {
    var data = remoteTracks[sid];
    if (data) { data.tileEl.remove(); delete remoteTracks[sid]; }
    if (screenSid === sid) { screenSid = null; screenTrack = null; setScreenUI(false); }
    if (pinnedId === sid) { pinParticipant('local'); }
}

// ── Pin ──────────────────────────────────────────────────────────────────────
function pinParticipant(id) {
    pinnedId = id;
    document.querySelectorAll('.s-tile').forEach(function(t){ t.classList.remove('pinned'); });

    var mainVideo   = document.getElementById('mainVideo');
    var mainAvatar  = document.getElementById('mainAvatar');
    var mainLblText = document.getElementById('mainLabelText');
    var mainMuted   = document.getElementById('mainMutedBadge');
    var screenBadge = document.getElementById('mainScreenBadge');

    mainAvatar.style.display  = 'none';
    mainVideo.style.display   = 'none';
    screenBadge.style.display = 'none';
    mainMuted.classList.remove('show');

    if (id === 'local') {
        mainLblText.innerText = 'You';
        if (room && room.localParticipant) {
            var vTracks = [];
            if (room.localParticipant.videoTracks) {
                room.localParticipant.videoTracks.forEach(function(publication) {
                    if (publication && publication.track) { vTracks.push(publication.track); }
                });
            }
            if (vTracks.length > 0 && camEnabled) {
                vTracks[0].attach(mainVideo);
                mainVideo.style.display = 'block';
                mainAvatar.style.display = 'none';
            } else {
                mainVideo.style.display = 'none';
                mainAvatar.style.display = 'flex';
            }
        } else {
            mainAvatar.style.display = 'flex';
        }
        if (!micEnabled) mainMuted.classList.add('show');

        var lt = document.getElementById('s_local');
        if (lt) lt.classList.add('pinned');

    } else {
        var data = remoteTracks[id];
        if (!data) { pinParticipant('local'); return; }

        // Local screen share: use stored stream
        if (data.isScreenLocal && data.stream) {
            mainVideo.srcObject = data.stream;
            mainVideo.style.display = 'block';
        } else {
            if (!data || !data.track || typeof data.track.attach !== 'function') {
                console.error('[PIN] track missing for sid:', id, 'falling back to local');
                pinParticipant('local');
                return;
            }
            data.track.attach(mainVideo);
            mainVideo.style.display = 'block';
        }

        mainLblText.innerText = data.name + (data.isScreen ? ' · Screen' : '');
        if (data.isScreen) screenBadge.style.display = 'block';

        var tile = document.getElementById('s_' + id);
        if (tile) tile.classList.add('pinned');
    }
}

// ── Mic ──────────────────────────────────────────────────────────────────────
function setMicUI(on) {
    document.getElementById('micOnIcon').style.display  = on ? 'block' : 'none';
    document.getElementById('micOffIcon').style.display = on ? 'none'  : 'block';
    document.getElementById('micLabel').innerText = on ? 'Mute' : 'Unmute';
    document.getElementById('micBtn').classList.toggle('off', !on);

    var sm = document.getElementById('s_local_muted');
    if (sm) sm.classList.toggle('show', !on);
    if (pinnedId === 'local') {
        document.getElementById('mainMutedBadge').classList.toggle('show', !on);
    }
}

async function toggleMic() {
    if (!room || !room.localParticipant || !micAvailable) return;
    micEnabled = !micEnabled;
    try {
        await room.localParticipant.setMicrophoneEnabled(micEnabled);
        setMicUI(micEnabled);
        showToast(micEnabled ? 'Mic on' : 'Mic muted');
    } catch(e) { micEnabled = !micEnabled; console.error(e); }
}

// ── Camera ───────────────────────────────────────────────────────────────────
function setCamUI(on) {
    document.getElementById('camOnIcon').style.display  = on ? 'block' : 'none';
    document.getElementById('camOffIcon').style.display = on ? 'none'  : 'block';
    document.getElementById('camLabel').innerText = on ? 'Stop Cam' : 'Start Cam';
    document.getElementById('camBtn').classList.toggle('off', !on);
    if (pinnedId === 'local') {
        document.getElementById('mainVideo').style.display  = on ? 'block' : 'none';
        document.getElementById('mainAvatar').style.display = on ? 'none'  : 'flex';
    }
}

async function toggleCam() {
    if (!room || !room.localParticipant || !camAvailable) return;
    camEnabled = !camEnabled;
    try {
        await room.localParticipant.setCameraEnabled(camEnabled);
        setCamUI(camEnabled);
        showToast(camEnabled ? 'Camera on' : 'Camera off');
    } catch(e) { camEnabled = !camEnabled; console.error(e); }
}

// ── Screen share ─────────────────────────────────────────────────────────────
function setScreenUI(on) {
    document.getElementById('screenLabel').innerText = on ? 'Stop Sharing' : 'Share Screen';
    document.getElementById('screenBtn').classList.toggle('screen-on', on);
}

async function toggleScreen() {
    if (!room || !room.localParticipant) return;

    if (screenTrack) {
        try { await room.localParticipant.unpublishTrack(screenTrack); screenTrack.stop(); } catch(e){}
        if (screenSid) {
            var el = document.getElementById('s_' + screenSid);
            if (el) el.remove();
            if (pinnedId === screenSid) pinParticipant('local');
            delete remoteTracks[screenSid];
            screenSid = null;
        }
        screenTrack = null;
        setScreenUI(false);
        showToast('Screen sharing stopped');
        return;
    }

    try {
        var stream = await navigator.mediaDevices.getDisplayMedia({ video:true, audio:false });
        var mediaTrack = stream.getVideoTracks()[0];

        mediaTrack.addEventListener('ended', function() {
            if (screenTrack) { toggleScreen(); }
        });

        var lsTrack = new sdk.LocalVideoTrack(mediaTrack);
        await room.localParticipant.publishTrack(lsTrack, {
            source: sdk.Track && sdk.Track.Source ? sdk.Track.Source.ScreenShare : 'screen_share'
        });

        screenTrack = lsTrack;
        var sid = 'screen_' + Date.now();
        screenSid = sid;

        var tile = makeSidebarTile('s_' + sid, 'Your Screen', true);
        tile.onclick = function(){ pinParticipant(sid); };

        var v = document.createElement('video');
        v.autoplay = true; v.muted = true; v.playsinline = true;
        v.style.cssText = 'width:100%;height:100%;object-fit:cover;display:block;';
        v.srcObject = stream;
        tile.insertBefore(v, tile.firstChild);

        document.getElementById('sidebar').appendChild(tile);

        remoteTracks[sid] = {
            track: lsTrack, name: 'Your Screen', isScreen: true,
            isScreenLocal: true, stream: stream,
            tileEl: tile, videoEl: v
        };

        pinParticipant(sid);
        setScreenUI(true);
        showToast('Screen sharing started');
    } catch(e) {
        if (e.name !== 'NotAllowedError') {
            showToast('Screen share failed: ' + e.message, 4000);
            console.error(e);
        }
    }
}

// ── End call ─────────────────────────────────────────────────────────────────
async function endCall() {
    if (screenTrack) {
        try { screenTrack.stop(); await room.localParticipant.unpublishTrack(screenTrack); } catch(e){}
    }
    if (room) { try { await room.disconnect(); } catch(e){} room = null; }
    clearInterval(timerInterval);
    window.close();
    setTimeout(function() {
        document.body.innerHTML = '<div style="display:flex;align-items:center;justify-content:center;height:100vh;font-family:DM Sans,sans-serif;color:#6b7280;font-size:14px;background:#0a0b0d;letter-spacing:.02em;">Call ended — you can close this tab.</div>';
    }, 300);
}

// ── Keyboard ──────────────────────────────────────────────────────────────────
document.addEventListener('keydown', function(e) {
    if (e.target.tagName === 'INPUT') return;
    if (e.key === 'd') toggleMic();
    if (e.key === 'e') toggleCam();
    if (e.key === 'Escape') endCall();
});
</script>
</body>
</html> --}}
<!DOCTYPE html>
<html>
<head>
    <title>Video Call - MeshCentral</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <script src="/scripts/livekit-client.umd.min.js"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --bg:          #0a0b0d;
            --surface:     #111316;
            --surface2:    #1a1d22;
            --surface3:    #22262d;
            --border:      rgba(255,255,255,0.07);
            --border2:     rgba(255,255,255,0.12);
            --text:        #f0f2f5;
            --text-dim:    #6b7280;
            --text-mid:    #9ca3af;
            --accent:      #3b82f6;
            --accent-glow: rgba(59,130,246,0.22);
            --green:       #22c55e;
            --red:         #ef4444;
            --red-dim:     rgba(239,68,68,0.14);
            --yellow:      #f59e0b;
            --radius:      12px;
            --radius-sm:   8px;
        }

        body {
            background: var(--bg);
            color: var(--text);
            font-family: 'DM Sans', sans-serif;
            height: 100vh;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            user-select: none;
        }

        /* ── TOP BAR ────────────────────────────────────────── */
        #topBar {
            height: 52px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 18px;
            background: var(--bg);
            border-bottom: 1px solid var(--border);
            flex-shrink: 0;
            z-index: 10;
        }

        #callInfo { display: flex; align-items: center; gap: 10px; }

        #statusPill {
            display: flex; align-items: center; gap: 6px;
            background: var(--surface2);
            border: 1px solid var(--border2);
            border-radius: 20px;
            padding: 4px 10px 4px 8px;
            font-size: 12px; font-weight: 500;
            color: var(--text-mid);
            transition: border-color 0.3s, color 0.3s;
        }
        #statusPill.connected { border-color: rgba(34,197,94,0.35); color: var(--green); }
        #statusPill.error     { border-color: rgba(239,68,68,0.35); color: var(--red); }

        #statusDot {
            width: 7px; height: 7px; border-radius: 50%;
            background: var(--yellow); flex-shrink: 0;
            transition: background 0.3s;
        }
        #statusPill.connected #statusDot { background: var(--green); box-shadow: 0 0 6px var(--green); }
        #statusPill.error     #statusDot { background: var(--red); }
        #statusPill.connecting #statusDot { animation: blink 1.4s ease-in-out infinite; }
        @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.2} }

        #roomLabel { font-size: 12px; font-weight: 500; color: var(--text-dim); }

        /* ── RECORDING BUTTON ── */
        #recordBtn {
            display: flex; align-items: center; gap: 6px;
            background: var(--surface2);
            border: 1px solid var(--border2);
            border-radius: 20px;
            padding: 4px 10px 4px 8px;
            font-size: 12px; font-weight: 500;
            color: var(--text-mid);
            cursor: pointer;
            transition: background 0.2s, border-color 0.2s, color 0.2s;
            font-family: 'DM Sans', sans-serif;
        }
        #recordBtn:hover:not(:disabled) {
            background: var(--surface3); border-color: var(--border); color: var(--text);
        }
        #recordBtn:disabled {
            opacity: 0.5; cursor: not-allowed;
        }
        #recordDot {
            width: 7px; height: 7px; border-radius: 50%;
            background: var(--text-dim); flex-shrink: 0;
            transition: background 0.2s, box-shadow 0.2s;
        }
        #recordBtn.recording {
            background: var(--red-dim);
            border-color: rgba(239,68,68,0.35);
            color: var(--red);
        }
        #recordBtn.recording #recordDot {
            background: var(--red);
            box-shadow: 0 0 6px var(--red);
            animation: blink 1.4s ease-in-out infinite;
        }

        /* ── TOP-RIGHT: timer + participant badge ── */
        #topRight { display: flex; align-items: center; gap: 8px; }

        #callTimer {
            font-family: 'DM Mono', monospace;
            font-size: 13px; color: var(--text-dim);
            background: var(--surface2);
            padding: 4px 10px; border-radius: 6px;
            border: 1px solid var(--border);
            letter-spacing: 0.04em;
        }

        /* Participant count pill */
        #participantPill {
            display: flex; align-items: center; gap: 5px;
            background: var(--surface2);
            border: 1px solid var(--border2);
            border-radius: 20px;
            padding: 4px 10px 4px 8px;
            font-size: 12px; font-weight: 500;
            color: var(--text-mid);
